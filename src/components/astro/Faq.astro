---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
}

const { items, title = 'FAQ' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<section class="mt-16" id="section-faq">
  <div class="flex items-center gap-3">
    <span class="h-6 w-1 flex-shrink-0 rounded-full bg-accent"></span>
    <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">{title}</h2>
  </div>

  <div class="mt-6 space-y-3">
    {
      items.map((item, i) => (
        <details
          class="group rounded-2xl border border-line bg-paper transition-all open:border-accent/30 open:shadow-lg open:shadow-accent/5"
          name="faq"
        >
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left">
            <span class="font-display text-base font-semibold tracking-tight text-ink group-open:text-accent">
              {item.question}
            </span>
            <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full border border-line text-ink-faint transition-all group-open:rotate-45 group-open:border-accent group-open:text-accent">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
                <path d="M12 5v14M5 12h14" />
              </svg>
            </span>
          </summary>
          <div class="px-5 pb-5 text-sm leading-relaxed text-ink-soft">{item.answer}</div>
        </details>
      ))
    }
  </div>
</section>

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
