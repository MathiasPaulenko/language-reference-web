---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localePath, sectionPath, pageAlternates } from '../../../lib/utils';
import { getUI, languageName } from '../../../i18n';
import { interfaceLocales, analyzedLanguages, type LocaleCode, type AnalyzedLanguageCode } from '../../../config/languages';
import FlagIcon from '../../../components/astro/FlagIcon.astro';

export const getStaticPaths = (() =>
  interfaceLocales.flatMap((locale) =>
    analyzedLanguages.map((l) => ({
      params: { lang: locale.code, languageCode: l.code },
    }))
  )) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
const languageCode = Astro.params.languageCode as AnalyzedLanguageCode;
const alternates = pageAlternates(`learning-paths/${languageCode}`);

const language = analyzedLanguages.find((l) => l.code === languageCode);
if (!language) {
  throw new Error(`Language ${languageCode} not found`);
}

const allTopics = await getCollection('topics');
// Group by topic field, prefer current locale with fallback to 'en'
const topicsByTopic = new Map();
for (const t of allTopics.filter((t) => !t.data.draft)) {
  const topicKey = t.data.topic;
  const existing = topicsByTopic.get(topicKey);
  if (!existing) {
    topicsByTopic.set(topicKey, t);
  } else if (t.data.locale === lang) {
    topicsByTopic.set(topicKey, t);
  } else if (t.data.locale === 'en' && existing.data.locale !== lang) {
    topicsByTopic.set(topicKey, t);
  }
}
const published = Array.from(topicsByTopic.values());

const byDifficulty = {
  beginner: published.filter((t) => t.data.difficulty === 'beginner'),
  intermediate: published.filter((t) => t.data.difficulty === 'intermediate'),
  advanced: published.filter((t) => t.data.difficulty === 'advanced'),
};

const stages = [
  {
    key: 'beginner',
    label: ui.learningPaths.stageBeginnerLabel,
    desc: ui.learningPaths.stageBeginnerDesc,
    color: '#2f7a6b',
  },
  {
    key: 'intermediate',
    label: ui.learningPaths.stageIntermediateLabel,
    desc: ui.learningPaths.stageIntermediateDesc,
    color: '#b4452a',
  },
  {
    key: 'advanced',
    label: ui.learningPaths.stageAdvancedLabel,
    desc: ui.learningPaths.stageAdvancedDesc,
    color: '#2b5c8a',
  },
];

function getLevelLabel(difficulty: string, langCode: string): string {
  if (langCode === 'chinese') {
    if (difficulty === 'beginner') return 'HSK 1–2';
    if (difficulty === 'intermediate') return 'HSK 3–4';
    if (difficulty === 'advanced') return 'HSK 5–6';
  }
  // Default: CEFR for English, Spanish, etc.
  if (difficulty === 'beginner') return 'A1–A2';
  if (difficulty === 'intermediate') return 'B1–B2';
  if (difficulty === 'advanced') return 'C1–C2';
  return difficulty;
}
---

<BaseLayout
  title={`${languageName(ui, languageCode)} ${ui.learningPaths.pathSuffix} | ${ui.site.name}`}
  description={ui.learningPaths.heroDesc}
  lang={lang}
  alternates={alternates}
  jsonLd={{
    '@type': 'WebPage',
    name: `${languageName(ui, languageCode)} ${ui.learningPaths.pathSuffix}`,
    description: ui.learningPaths.heroDesc,
    inLanguage: lang,
  }}
>
  {/* Hero */}
  <section class="border-b border-line bg-[#2a2520]">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.nav.learningPaths}</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">
        {languageName(ui, languageCode)} {ui.learningPaths.pathSuffix}
      </h1>
      <p class="mt-4 max-w-xl text-lg text-paper/70">
        {ui.learningPaths.heroDesc}
      </p>
    </div>
  </section>

  {/* Breadcrumb */}
  <nav aria-label="Breadcrumb" class="mx-auto mt-6 flex max-w-6xl items-center gap-2 px-5 text-xs text-ink-faint sm:px-8">
    <a href={localePath(lang)} class="transition-colors hover:text-accent">{ui.nav.home}</a>
    <span>/</span>
    <a href={localePath(lang, 'learning-paths')} class="transition-colors hover:text-accent">{ui.nav.learningPaths}</a>
    <span>/</span>
    <span class="text-ink-soft">{languageName(ui, languageCode)}</span>
  </nav>

  {/* Progress summary */}
  <section class="mx-auto mt-12 max-w-6xl px-5 sm:px-8">
    <div class="grid gap-4 sm:grid-cols-3">
      {stages.map((stage) => (
        <div class="rounded-2xl border border-line bg-paper-deep p-6">
          <div class="flex items-center gap-2">
            <span class="h-3 w-3 rounded-full" style={`background:${stage.color}`} />
            <span class="font-mono text-xs font-bold uppercase tracking-wider text-ink-faint">{stage.label}</span>
          </div>
          <p class="mt-2 text-2xl font-display font-semibold text-ink">{byDifficulty[stage.key as keyof typeof byDifficulty].length}</p>
          <p class="text-sm text-ink-soft">{ui.learningPaths.topicsCount.replace('{count}', String(byDifficulty[stage.key as keyof typeof byDifficulty].length))}</p>
        </div>
      ))}
    </div>
  </section>

  {/* Roadmap */}
  <section class="mx-auto mb-16 mt-12 max-w-6xl px-5 sm:px-8">
    <div class="space-y-16">
      {stages.map((stage, stageIdx) => {
        const topics = byDifficulty[stage.key as keyof typeof byDifficulty];
        return (
          <div>
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full font-display text-sm font-semibold text-white" style={`background:${stage.color}`}>
                {stageIdx + 1}
              </span>
              <div>
                <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">{stage.label}</h2>
                <p class="text-sm text-ink-soft">{stage.desc}</p>
              </div>
              <span class="ml-auto rounded-full bg-paper-deep px-3 py-1 font-mono text-xs font-semibold text-ink-faint">
                {ui.learningPaths.topicsCount.replace('{count}', String(topics.length))}
              </span>
            </div>

            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {topics.map((topic, idx) => (
                <a
                  href={`${sectionPath(lang, 'topics', topic.data.topic)}?lang=${languageCode}`}
                  class="group flex flex-col rounded-xl border border-line bg-paper p-6 transition-all hover:shadow-lg hover:border-accent/20"
                  style={`border-left: 3px solid ${stage.color}`}
                >
                  <div class="flex items-center justify-between">
                    <span class="font-mono text-xs text-ink-faint">{String(idx + 1).padStart(2, '0')}</span>
                    <span class="rounded-full bg-paper-deep px-2 py-0.5 font-mono text-[10px] font-bold uppercase tracking-wider text-ink-faint">
                      {getLevelLabel(topic.data.difficulty ?? 'beginner', languageCode)}
                    </span>
                  </div>
                  <h3 class="mt-3 font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
                    {topic.data.title}
                  </h3>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft">{topic.data.description}</p>
                  <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-accent transition-transform group-hover:translate-x-1">
                    {ui.learningPaths.learn} <span>→</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>
</BaseLayout>
