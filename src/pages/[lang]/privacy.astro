---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
---

<BaseLayout
  title={`${ui.footer.privacy} | ${ui.site.name}`}
  description={ui.legal.privacyDesc}
  lang={lang}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.legal.label}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.footer.privacy}</h1>
    <div class="mt-8 space-y-6 leading-relaxed text-ink-soft">
      <p>{ui.legal.privacyDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Information we collect</h2>
      <p>
        We use Google Analytics 4 to understand how visitors interact with the site. This may include
        anonymized data such as pages visited, time on site, and approximate location (country/city level).
        We do not collect personally identifiable information unless you voluntarily contact us via email.
      </p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">How we use cookies</h2>
      <p>
        We use cookies for analytics and, with your consent, for personalized advertising via Google AdSense.
        You can manage your cookie preferences at any time through the cookie banner or your browser settings.
      </p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Your rights</h2>
      <p>
        You have the right to access, rectify, or delete any personal data we hold. To exercise these rights,
        please contact us at <a href="mailto:mathias.paulenko@outlook.com" class="text-accent transition-colors hover:underline">mathias.paulenko@outlook.com</a>.
      </p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Third-party services</h2>
      <p>
        We rely on trusted third-party services including Google Analytics, Google AdSense, and GitHub Pages
        for hosting. These services have their own privacy policies.
      </p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Changes to this policy</h2>
      <p>
        We may update this Privacy Policy from time to time. Any changes will be posted on this page
        with an updated revision date.
      </p>
    </div>
  </main>
</BaseLayout>
