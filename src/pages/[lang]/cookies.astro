---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
---

<BaseLayout
  title={`${ui.footer.cookies} | ${ui.site.name}`}
  description={ui.legal.cookiesDesc}
  lang={lang}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.legal.label}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.footer.cookies}</h1>
    <div class="mt-8 space-y-6 leading-relaxed text-ink-soft">
      <p>{ui.legal.cookiesDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">What are cookies?</h2>
      <p>
        Cookies are small text files stored on your device when you visit a website. They help the site
        remember your preferences, understand how you use it, and deliver relevant content.
      </p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Types of cookies we use</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5">
        <li>
          <strong class="text-ink">Analytics cookies</strong> — Help us understand how visitors interact with the site
          (via Google Analytics).
        </li>
        <li>
          <strong class="text-ink">Advertising cookies</strong> — Used by Google AdSense to serve personalized ads
          (only with your consent).
        </li>
        <li>
          <strong class="text-ink">Functional cookies</strong> — Remember your language preference and cookie consent choice.
        </li>
      </ul>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Managing cookies</h2>
      <p>
        You can manage or delete cookies at any time through your browser settings. You can also update
        your consent preferences using the cookie banner at the bottom of the page.
      </p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">Third-party cookies</h2>
      <p>
        We use third-party services (Google Analytics, Google AdSense) that may set their own cookies.
        These services have independent cookie policies.
      </p>
    </div>
  </main>
</BaseLayout>
