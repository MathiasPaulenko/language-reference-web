---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localePath, pageAlternates } from '../../../lib/utils';
import { getUI } from '../../../i18n';
import { interfaceLocales, type LocaleCode } from '../../../config/languages';

export const getStaticPaths = (() =>
  interfaceLocales.flatMap((locale) => [
    { params: { lang: locale.code, slug: undefined } },
  ])) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
const alternates = pageAlternates('flashcards');

const flashcards = [
  { key: 'grammar', title: ui.nav.grammar, desc: ui.flashcards.grammarDesc, icon: 'layers' },
  { key: 'vocabulary', title: ui.nav.vocabulary, desc: ui.flashcards.vocabularyDesc, icon: 'book' },
  { key: 'phrases', title: ui.nav.phrases, desc: ui.flashcards.phrasesDesc, icon: 'message' },
];
---

<BaseLayout
  title={`${ui.landing.flashcardsTitle} | ${ui.site.name}`}
  description={ui.landing.flashcardsDesc}
  lang={lang}
  alternates={alternates}
  jsonLd={{
    '@type': 'WebPage',
    name: ui.landing.flashcardsTitle,
    description: ui.landing.flashcardsDesc,
    inLanguage: lang,
  }}
>
  <section class="border-b border-line bg-[#2a2520]">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.landing.flashcardsTitle}</p>
        <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">{ui.landing.flashcardsSubtitle}</h1>
        <p class="mt-4 max-w-xl text-lg text-paper/70">{ui.landing.flashcardsDesc}</p>
      </div>
    </section>

  <section class="border-y border-line bg-paper-deep">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
        <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.landing.methodLabel}</p>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.howFlashcardsTitle}</h2>
        <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { num: '01', title: ui.landing.howFlashcards1Title, body: ui.landing.howFlashcards1Body },
            { num: '02', title: ui.landing.howFlashcards2Title, body: ui.landing.howFlashcards2Body },
            { num: '03', title: ui.landing.howFlashcards3Title, body: ui.landing.howFlashcards3Body },
            { num: '04', title: ui.landing.howFlashcards4Title, body: ui.landing.howFlashcards4Body },
          ].map((step) => (
            <div class="group relative flex flex-col rounded-2xl border border-line bg-paper p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10 font-mono text-sm font-bold text-accent transition-colors group-hover:bg-accent group-hover:text-paper">
                  {step.num}
                </span>
              </div>
              <h3 class="mt-5 font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Flip card demo */}
    <section class="mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.flashcards.tryIt}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.flashcards.flipACard}</h2>
      <p class="mt-3 text-ink-soft">{ui.flashcards.demoInstruction}</p>

      <div class="mt-10 flex justify-center">
        <div class="perspective-[1000px] w-80 sm:w-96">
          <div id="demo-card" class="flip-card relative h-56 w-full cursor-pointer" style="transform-style: preserve-3d; transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);">
            {/* Front */}
            <div class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl border-2 border-accent/20 bg-paper shadow-sm" style="backface-visibility: hidden;">
              <span class="font-mono text-xs uppercase tracking-wider text-ink-faint">{ui.nav.grammar}</span>
              <p class="mt-3 px-6 text-center font-display text-xl font-semibold text-ink">{ui.flashcards.demoQuestion}</p>
              <span class="mt-6 text-xs text-ink-faint">{ui.flashcards.clickToReveal}</span>
            </div>
            {/* Back */}
            <div class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl border-2 border-accent bg-accent/5 shadow-sm" style="backface-visibility: hidden; transform: rotateY(180deg);">
              <span class="font-mono text-xs uppercase tracking-wider text-accent">{ui.flashcards.answer}</span>
              <p class="mt-3 px-6 text-center font-display text-lg font-semibold text-ink">{ui.flashcards.demoAnswer}</p>
              <p class="mt-2 px-6 text-center text-sm text-ink-soft">{ui.flashcards.demoExample}</p>
            </div>
          </div>
        </div>
      </div>

      <script>
        const card = document.getElementById('demo-card');
        let flipped = false;
        if (card) {
          card.addEventListener('click', () => {
            flipped = !flipped;
            card.style.transform = flipped ? 'rotateY(180deg)' : '';
          });
        }
      </script>
    </section>

    {/* Deck cards */}
    <section class="border-t border-line bg-paper-deep">
      <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.flashcards.decks}</p>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.flashcards.chooseADeck}</h2>

        <div class="mt-10 grid gap-6 sm:grid-cols-3">
          {flashcards.map((deck) => (
            <a href={localePath(lang, `flashcards/${deck.key}`)} class="group flex flex-col rounded-2xl border border-line bg-paper p-8 transition-all hover:shadow-lg hover:border-accent/30">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-accent/10 text-accent transition-transform group-hover:scale-110">
                {deck.icon === 'layers' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                )}
                {deck.icon === 'book' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                )}
                {deck.icon === 'message' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                )}
              </div>
              <h3 class="mt-6 font-display text-2xl font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">{deck.title}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft">{deck.desc}</p>
              <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-accent transition-transform group-hover:translate-x-1">
                {ui.flashcards.startDeck} <span>→</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

  </BaseLayout>
