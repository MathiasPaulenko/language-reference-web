---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';
import { pageAlternates } from '../../lib/utils';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
const alternates = pageAlternates('affiliate');
---

<BaseLayout
  title={`${ui.nav.affiliate} | ${ui.site.name}`}
  description={ui.legal.affiliateDesc}
  lang={lang}
  alternates={alternates}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.legal.label}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.nav.affiliate}</h1>
    <div class="mt-8 space-y-6 leading-relaxed text-ink-soft">
      <p>{ui.legal.affiliateDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.affiliateTransparentTitle}</h2>
      <p>{ui.legal.affiliateTransparentDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.affiliateCostTitle}</h2>
      <p>{ui.legal.affiliateCostDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.affiliateIndependentTitle}</h2>
      <p>{ui.legal.affiliateIndependentDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.affiliateAdvertisingTitle}</h2>
      <p>{ui.legal.affiliateAdvertisingDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.affiliateDonationsTitle}</h2>
      <p>{ui.legal.affiliateDonationsDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.affiliateFtcTitle}</h2>
      <p>{ui.legal.affiliateFtcDesc}</p>
    </div>
  </main>
</BaseLayout>
