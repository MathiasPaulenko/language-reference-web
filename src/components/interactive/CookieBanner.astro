---
import { localePath } from '../../lib/utils';

interface Props {
  lang: string;
  banner: string;
  accept: string;
  decline: string;
  privacyHref: string;
}

const { lang, banner, accept, decline, privacyHref } = Astro.props;
---

<div
  id="cookie-banner"
  class="fixed bottom-4 left-4 right-4 z-50 hidden max-w-2xl translate-y-2 rounded-2xl border border-line bg-paper p-4 shadow-lg sm:left-auto sm:right-6"
  data-lang={lang}
  data-banner={banner}
  data-accept={accept}
  data-decline={decline}
  data-privacy={privacyHref}
>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm leading-relaxed text-ink-soft">
      {banner}
      <a href={privacyHref} class="ml-1 font-semibold text-accent hover:underline">Privacy</a>
    </p>
    <div class="flex shrink-0 gap-2">
      <button
        id="cookie-decline"
        class="rounded-full border border-line px-4 py-2 text-xs font-semibold text-ink-soft transition-colors hover:bg-paper-deep"
      >
        {decline}
      </button>
      <button
        id="cookie-accept"
        class="rounded-full bg-accent px-4 py-2 text-xs font-semibold text-paper transition-colors hover:bg-accent-soft"
      >
        {accept}
      </button>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'ga_cookie_consent';
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  if (banner && acceptBtn && declineBtn) {
    const stored = localStorage.getItem(STORAGE_KEY);

    if (stored === null) {
      banner.classList.remove('hidden');
      banner.classList.add('animate-slide-up');
    }

    const setConsent = (granted: boolean) => {
      localStorage.setItem(STORAGE_KEY, granted ? 'granted' : 'denied');
      banner.classList.add('hidden');

      if (typeof window.gtag === 'function') {
        window.gtag('consent', 'update', {
          analytics_storage: granted ? 'granted' : 'denied',
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
        });
      }
    };

    acceptBtn.addEventListener('click', () => setConsent(true));
    declineBtn.addEventListener('click', () => setConsent(false));
  }

  // Default consent before user choice
  if (typeof window.gtag === 'function') {
    window.gtag('consent', 'default', {
      analytics_storage: 'denied',
      ad_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
    });
  }
</script>

<style>
  .animate-slide-up {
    animation: slideUp 0.4s ease-out forwards;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
