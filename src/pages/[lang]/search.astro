---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { interfaceLocales, type LocaleCode } from '../../config/languages';
import { getUI } from '../../i18n';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
---

<BaseLayout title={`${ui.nav.search} — ${ui.site.name}`} description={ui.site.tagline} lang={lang}>
  <section class="mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-24">
    <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.nav.search}</h1>
    <p class="mt-3 text-ink-soft">{ui.site.tagline}</p>

    <div id="search" class="mt-10"></div>
    <p id="search-status" class="mt-4 text-sm text-ink-faint">{ui.search.loading}</p>
  </section>
</BaseLayout>

<script define:vars={{ pagefindTranslations: JSON.stringify({
  placeholder: ui.pagefind.placeholder,
  clear_search: ui.pagefind.clear_search,
  load_more: ui.pagefind.load_more,
  search_label: ui.pagefind.search_label,
  filters_label: ui.pagefind.filters_label,
  zero_results: ui.pagefind.zero_results,
  many_results: ui.pagefind.many_results,
  one_result: ui.pagefind.one_result,
  alt_search: ui.pagefind.alt_search,
}), searchIndexMissing: ui.placeholders.searchIndexMissing }}>
  const translations = JSON.parse(pagefindTranslations);
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const searchEl = document.getElementById('search');
  const statusEl = document.getElementById('search-status');

  async function init() {
    try {
      const mod = await import(/* @vite-ignore */ `${base}/pagefind/pagefind-ui.js`);
      if (mod.PagefindUI && searchEl) {
        new mod.PagefindUI({
          element: '#search',
          showSubResults: true,
          showImages: false,
          translations,
        });
        if (statusEl) statusEl.style.display = 'none';
      }
    } catch (err) {
      console.warn('Pagefind UI not available (run build first):', err);
      if (searchEl) searchEl.innerHTML = `<p class="text-ink-faint">${searchIndexMissing}</p>`;
    }
  }

  init();
</script>

<style is:global>
  /* Pagefind UI theme overrides to match editorial design */
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: #b4452a;
    --pagefind-ui-text: #1a1a1a;
    --pagefind-ui-background: #faf8f5;
    --pagefind-ui-border: #e5e0d8;
    --pagefind-ui-tag: #f4f1ec;
    --pagefind-ui-font: 'Public Sans', ui-sans-serif, system-ui, sans-serif;
  }
  .pagefind-ui .pagefind-ui__search-input {
    border-radius: 9999px !important;
    padding: 0.75rem 1.25rem !important;
    font-size: 1rem !important;
  }
  .pagefind-ui .pagefind-ui__search-clear {
    border-radius: 9999px !important;
  }
</style>
