---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';
import { pageAlternates } from '../../lib/utils';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
const alternates = pageAlternates('privacy');
---

<BaseLayout
  title={`${ui.footer.privacy} | ${ui.site.name}`}
  description={ui.legal.privacyDesc}
  lang={lang}
  alternates={alternates}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.legal.label}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.footer.privacy}</h1>
    <div class="mt-8 space-y-6 leading-relaxed text-ink-soft">
      <p>{ui.legal.privacyDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.privacyInfoTitle}</h2>
      <p>{ui.legal.privacyInfoDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.privacyCookiesTitle}</h2>
      <p>{ui.legal.privacyCookiesDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.privacyRightsTitle}</h2>
      <p>{ui.legal.privacyRightsDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.privacyThirdTitle}</h2>
      <p>{ui.legal.privacyThirdDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.privacyChangesTitle}</h2>
      <p>{ui.legal.privacyChangesDesc}</p>
    </div>
  </main>
</BaseLayout>
