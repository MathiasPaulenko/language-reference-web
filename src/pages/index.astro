---
import { DEFAULT_LOCALE } from '../config/languages';
import { localePath } from '../lib/utils';
import { getUI } from '../i18n';

const ui = getUI(DEFAULT_LOCALE);

// Static landing redirect: GitHub Pages has no server, so we emit an HTML
// page that forwards visitors to the default-locale home (/en/).
const target = localePath(DEFAULT_LOCALE);
---

<!DOCTYPE html>
<html lang={DEFAULT_LOCALE}>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="description" content="Understand grammar through language comparison. Spanish, English and Chinese grammar concepts explained side by side." />
    <link rel="canonical" href={target} />
    <title>Grammar Navigator</title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Grammar Navigator" />
    <meta property="og:title" content="Grammar Navigator" />
    <meta property="og:description" content="Understand grammar through language comparison. Spanish, English and Chinese grammar concepts explained side by side." />
    <meta property="og:url" content="https://grammarnavigator.com" />
    <meta property="og:image" content="https://grammarnavigator.com/og-image.jpg" />
  </head>
  <body>
    <p>{ui.redirect.redirectingTo} <a href={target}>{ui.site.name}</a>…</p>
  </body>
</html>
