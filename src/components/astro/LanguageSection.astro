---
interface Props {
  language: 'spanish' | 'english' | 'chinese';
}

const { language } = Astro.props;

const config = {
  spanish: { bg: 'rgba(180, 69, 42, 0.06)', border: '#b4452a' },
  english: { bg: 'rgba(43, 92, 138, 0.06)', border: '#2b5c8a' },
  chinese: { bg: 'rgba(47, 122, 107, 0.06)', border: '#2f7a6b' },
};

const c = config[language];
---

<div class="my-8 rounded-2xl border-l-4 p-6 sm:p-8" style={`background: ${c.bg}; border-color: ${c.border};`}>
  <slot />
</div>
