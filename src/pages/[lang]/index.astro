---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath, sectionPath, withPinyin } from '../../lib/utils';
import { getUI, languageName } from '../../i18n';
import {
  interfaceLocales,
  analyzedLanguages,
  type LocaleCode,
} from '../../config/languages';
import FlagIcon from '../../components/astro/FlagIcon.astro';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);

const allTopics = await getCollection('topics');
const topics = allTopics
  .filter((t) => !t.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const legend = analyzedLanguages.map((l) => ({
  code: l.code,
  name: languageName(ui, l.code),
  color: l.color,
}));

const comparisonRows: { concept: string; values: Record<string, string> }[] = [
  { concept: 'Definite', values: { spanish: 'el libro', english: 'the book', chinese: '<ruby>这<rt>zhè</rt></ruby><ruby>本<rt>běn</rt></ruby><ruby>书<rt>shū</rt></ruby>' } },
  { concept: 'Indefinite', values: { spanish: 'un libro', english: 'a book', chinese: '<ruby>一<rt>yì</rt></ruby><ruby>本<rt>běn</rt></ruby><ruby>书<rt>shū</rt></ruby>' } },
  { concept: 'Plural', values: { spanish: 'los libros', english: 'the books', chinese: '<ruby>这<rt>zhè</rt></ruby><ruby>些<rt>xiē</rt></ruby><ruby>书<rt>shū</rt></ruby>' } },
  { concept: 'Generic', values: { spanish: 'los gatos', english: 'cats', chinese: '<ruby>猫<rt>māo</rt></ruby>' } },
  { concept: 'Zero article', values: { spanish: 'Ø agua', english: 'water', chinese: '<ruby>水<rt>shuǐ</rt></ruby>' } },
];

const steps = [
  { num: '01', title: ui.howItWorks.step1Title, body: ui.howItWorks.step1Body },
  { num: '02', title: ui.howItWorks.step2Title, body: ui.howItWorks.step2Body },
  { num: '03', title: ui.howItWorks.step3Title, body: ui.howItWorks.step3Body },
  { num: '04', title: ui.howItWorks.step4Title, body: ui.howItWorks.step4Body },
];
---

<BaseLayout
  title={`${ui.site.name} — ${ui.site.tagline}`}
  description={ui.hero.body}
  lang={lang}
  jsonLd={{
    '@type': 'WebSite',
    name: ui.site.name,
    description: ui.site.tagline,
    url: Astro.site ? new URL(localePath(lang), Astro.site).toString() : undefined,
    inLanguage: lang,
  }}
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-line bg-gradient-to-br from-[#ece3d0] via-[#f1ead8] to-[#e2d6c2]">
    <div class="hero-typo-bg">
      <!-- 30 normal letters (75%) -->
      <span class="typo-particle typo-particle--xl" aria-hidden="true">A</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">g</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">r</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">m</span>
      <span class="typo-particle" aria-hidden="true">M</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">a</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">n</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">L</span>
      <span class="typo-particle" aria-hidden="true">y</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">i</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">d</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">O</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">e</span>
      <span class="typo-particle" aria-hidden="true">P</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">a</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">g</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">e</span>
      <span class="typo-particle" aria-hidden="true">s</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">t</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">ñ</span>
      <span class="typo-particle" aria-hidden="true">ü</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">á</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">ó</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">ç</span>
      <span class="typo-particle" aria-hidden="true">l</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">ú</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">é</span>
      <span class="typo-particle" aria-hidden="true">à</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">b</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">h</span>
      <!-- 8 Chinese characters (20%) -->
      <span class="typo-particle typo-particle--xl" aria-hidden="true">文</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">的</span>
      <span class="typo-particle" aria-hidden="true">法</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">语</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">词</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">写</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">读</span>
      <span class="typo-particle" aria-hidden="true">学</span>
      <!-- 2 special characters (5%) -->
      <span class="typo-particle typo-particle--xl" aria-hidden="true">?</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">…</span>
    </div>
    <div class="relative z-10 mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="reveal font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent" style="animation-delay:0ms">
        {ui.hero.eyebrow}
      </p>
      <h1
        class="reveal mt-6 max-w-4xl flex flex-col leading-[1.1] tracking-tight"
        style="animation-delay:80ms"
      >
        <span class="font-script text-5xl text-ink sm:text-6xl lg:text-7xl">
          {ui.hero.titleLine1}
        </span>
        <span class="-mt-1 font-body text-4xl font-medium text-ink sm:text-5xl lg:text-6xl">
          {ui.hero.titleLine2}
        </span>
        <span class="mt-1 font-display text-3xl font-bold text-accent sm:text-4xl lg:text-5xl">
          {ui.hero.titleLine3}
        </span>
      </h1>
      <p class="reveal mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft" style="animation-delay:160ms">
        {ui.hero.body}
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center gap-4" style="animation-delay:240ms">
        <a
          href={sectionPath(lang, 'topics')}
          class="group inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-semibold text-paper transition-transform hover:-translate-y-0.5"
        >
          {ui.hero.ctaPrimary}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-2 rounded-full border border-ink px-6 py-3 text-sm font-semibold text-ink transition-colors hover:bg-ink hover:text-paper"
        >
          {ui.hero.ctaSecondary}
        </a>
      </div>

      <!-- Legend -->
      <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:320ms">
        {
          legend.map((l) => (
            <span class="group flex items-center transition-transform duration-300 hover:scale-110" aria-label={l.name}>
              <FlagIcon code={l.code} size={28} />
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Grammar Concepts (Topics) — PRIMARY NAVIGATION -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.topics}</p>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.topics.title}</h2>
        <p class="mt-3 max-w-xl text-ink-soft">{ui.topics.subtitle}</p>
      </div>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
      {
        topics.slice(0, 8).map((topic, i) => (
          <a
            href={sectionPath(lang, 'topics', topic.id)}
            class="group flex flex-col bg-paper p-7 transition-colors hover:bg-paper-deep"
          >
            <span class="font-mono text-xs text-ink-faint">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-4 font-display text-2xl font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
              {topic.data.title}
            </h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft" set:html={lang === 'zh' ? topic.data.description : withPinyin(topic.data.description)} />
            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-ink-faint transition-colors group-hover:text-accent">
              {ui.article.explanation}
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))
      }
      <a
        href={sectionPath(lang, 'topics')}
        class="group flex flex-col items-center justify-center bg-paper-deep p-7 transition-colors hover:bg-accent/5"
      >
        <span class="font-display text-lg font-semibold text-ink transition-colors group-hover:text-accent">
          {ui.topics.viewAll}
        </span>
        <span class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-accent transition-transform group-hover:translate-x-1">
          →
        </span>
      </a>
    </div>
  </section>

  <!-- How it Works -->
  <section id="how-it-works" class="border-y border-line bg-paper-deep">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">Method</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.howItWorks.title}</h2>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink-soft">{ui.howItWorks.intro}</p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, i) => (
            <div class="group relative flex flex-col rounded-2xl border border-line bg-paper p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10 font-mono text-sm font-bold text-accent transition-colors group-hover:bg-accent group-hover:text-paper">
                  {step.num}
                </span>
                {i < steps.length - 1 && (
                  <div class="hidden lg:block absolute top-10 left-full h-px w-6 border-t-2 border-dashed border-accent/20" />
                )}
              </div>
              <h3 class="mt-5 font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{step.body}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 flex items-center justify-center">
        <a
          href={sectionPath(lang, 'topics')}
          class="inline-flex items-center gap-2 rounded-full bg-ink px-8 py-4 text-base font-semibold text-paper transition-transform hover:-translate-y-0.5"
        >
          {ui.hero.ctaPrimary}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Side-by-side comparison — SECONDARY -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.comparisons}</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.comparisons.title}</h2>
    <p class="mt-3 max-w-xl text-ink-soft">{ui.comparisons.subtitle}</p>
    <p class="mt-2 max-w-3xl text-base leading-relaxed text-ink">{ui.comparisons.description}</p>

    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      {
        analyzedLanguages.map((l) => (
          <div class="flex flex-col items-center rounded-2xl border border-line bg-paper p-6 text-center transition-all duration-300 hover:-translate-y-1 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
            <div class="flex h-12 w-12 items-center justify-center rounded-full" style={`background-color: ${l.color}15`}>
              <FlagIcon code={l.code} size={24} />
            </div>
            <span class="mt-3 font-display text-sm font-semibold uppercase tracking-wider text-ink-faint">{languageName(ui, l.code)}</span>
            <div class="mt-4 rounded-xl bg-paper-deep px-4 py-3">
              <p class="font-display text-base font-semibold text-ink" set:html={l.code === 'spanish' ? 'el libro <span class="text-ink-faint">/ un libro</span>' : l.code === 'english' ? 'the book <span class="text-ink-faint">/ a book</span>' : '<ruby>这<rt>zhè</rt></ruby><ruby>本<rt>běn</rt></ruby><ruby>书<rt>shū</rt></ruby> <span class="text-ink-faint">/ <ruby>一<rt>yì</rt></ruby><ruby>本<rt>běn</rt></ruby><ruby>书<rt>shū</rt></ruby></span>'} />
            </div>
            <p class="mt-3 text-xs leading-relaxed text-ink-faint">
              {l.code === 'spanish' ? 'Articles for all references' : l.code === 'english' ? 'Articles only for specifics' : 'Demonstratives + measure words'}
            </p>
          </div>
        ))
      }
    </div>

    <div class="mt-10">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.comparisons.whyCompareTitle}</p>
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-line bg-paper-deep p-5">
          <span class="font-display text-2xl font-bold text-accent">01</span>
          <h3 class="mt-2 font-display text-sm font-semibold uppercase tracking-wider text-ink">{ui.comparisons.whyCompare1Title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{ui.comparisons.whyCompare1Body}</p>
        </div>
        <div class="rounded-2xl border border-line bg-paper-deep p-5">
          <span class="font-display text-2xl font-bold text-accent">02</span>
          <h3 class="mt-2 font-display text-sm font-semibold uppercase tracking-wider text-ink">{ui.comparisons.whyCompare2Title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{ui.comparisons.whyCompare2Body}</p>
        </div>
        <div class="rounded-2xl border border-line bg-paper-deep p-5">
          <span class="font-display text-2xl font-bold text-accent">03</span>
          <h3 class="mt-2 font-display text-sm font-semibold uppercase tracking-wider text-ink">{ui.comparisons.whyCompare3Title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-soft">{ui.comparisons.whyCompare3Body}</p>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-center">
      <a
        href={sectionPath(lang, 'comparisons')}
        class="group inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-semibold text-paper transition-transform hover:-translate-y-0.5"
      >
        {ui.comparisons.seeAllComparisons}
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
