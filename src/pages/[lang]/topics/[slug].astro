---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContentArticle from '../../../components/astro/ContentArticle.astro';
import { getUI } from '../../../i18n';
import { interfaceLocales, type LocaleCode } from '../../../config/languages';
import { contentAlternates } from '../../../lib/utils';

export async function getStaticPaths() {
  const entries = await getCollection('topics');
  // Group by topic field
  const byTopic = new Map();
  for (const entry of entries.filter((e) => !e.data.draft)) {
    const topicKey = entry.data.topic;
    if (!byTopic.has(topicKey)) byTopic.set(topicKey, new Map());
    byTopic.get(topicKey).set(entry.data.locale, entry);
  }

  const paths = [];
  for (const [topicId, localeMap] of byTopic) {
    for (const locale of interfaceLocales) {
      const entry = localeMap.get(locale.code) || localeMap.get('en');
      if (!entry) continue;
      paths.push({
        params: { lang: locale.code, slug: topicId },
        props: { entry, lang: locale.code, topicId, availableLocales: Array.from(localeMap.keys()) },
      });
    }
  }
  return paths;
}

const { entry, lang, topicId } = Astro.props;
const availableLocales = Astro.props.availableLocales as string[];
const ui = getUI(lang as LocaleCode);
const topicUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname;
const alternates = contentAlternates(topicId, 'topics', new Map(availableLocales.map((l) => [l, true])));

// Keep titles under 60 chars: drop site name if the full title would be too long
const fullTitle = `${entry.data.title} | ${ui.site.name}`;
const pageTitle = fullTitle.length <= 60 ? fullTitle : entry.data.title;
const topicsIndexUrl = Astro.site ? new URL(Astro.url.pathname.replace(/[^/]+\/$/, ''), Astro.site).toString() : Astro.url.pathname.replace(/[^/]+\/$/, '');
---

<BaseLayout
  title={pageTitle}
  description={entry.data.description}
  lang={lang}
  alternates={alternates}
  jsonLd={[
    {
      '@type': 'LearningResource',
      name: entry.data.title,
      description: entry.data.description,
      inLanguage: lang,
      dateModified: entry.data.lastUpdated?.toISOString(),
      author: {
        '@type': 'Organization',
        name: ui.site.name,
        url: 'https://grammarnavigator.com',
      },
      about: [ui.topics.spanishGrammar, ui.topics.englishGrammar, ui.topics.chineseGrammar],
      educationalLevel: entry.data.difficulty,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: ui.nav.home,
          item: Astro.site ? new URL(`/${lang}/`, Astro.site).toString() : `/${lang}/`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: ui.nav.topics,
          item: topicsIndexUrl,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: entry.data.title,
          item: topicUrl,
        },
      ],
    },
  ]}
>
  <ContentArticle entry={entry} lang={lang} />
</BaseLayout>
