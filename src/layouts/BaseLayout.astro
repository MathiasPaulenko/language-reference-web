---
import '../styles/global.css';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
import JsonLd from '../components/astro/JsonLd.astro';
import CookieBanner from '../components/interactive/CookieBanner.astro';
import {
  getLocale,
  localeCodes,
  DEFAULT_LOCALE,
  type LocaleCode,
} from '../config/languages';
import { localePath } from '../lib/utils';
import { getUI } from '../i18n';

interface Alternate {
  locale: LocaleCode;
  href: string;
}

interface Props {
  title: string;
  description: string;
  lang?: LocaleCode;
  /** Optional per-locale alternates; defaults to each locale's home. */
  alternates?: readonly Alternate[];
  /** Optional JSON-LD structured data payload(s). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, lang = DEFAULT_LOCALE, alternates, jsonLd } = Astro.props;
const locale = getLocale(lang) ?? getLocale(DEFAULT_LOCALE)!;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ui = getUI(lang);

// Build hreflang alternates (vision §8 SEO). Fall back to locale homes.
const altList: readonly Alternate[] =
  alternates ?? localeCodes.map((code) => ({ locale: code, href: localePath(code) }));
const altUrl = (href: string) => new URL(href, Astro.site).toString();
---

<!DOCTYPE html>
<html lang={locale.htmlLang} dir={locale.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="theme-color" content="#b4452a" />
    <meta name="apple-mobile-web-app-title" content="Grammar Navigator" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/manifest.json" />

    {
      altList.map((alt) => (
        <link rel="alternate" hreflang={getLocale(alt.locale)?.htmlLang ?? alt.locale} href={altUrl(alt.href)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={altUrl(localePath(DEFAULT_LOCALE))} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Grammar Navigator" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={locale.htmlLang} />
    <meta property="og:image" content="/og-image.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Grammar Navigator — Understand grammar through language comparison" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.svg" />
    <meta name="twitter:image:alt" content="Grammar Navigator — Understand grammar through language comparison" />

    {jsonLd && <JsonLd data={jsonLd} />}

    <!-- Favicon — SVG inline for modern browsers, no external file needed -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ccircle cx='50' cy='50' r='48' fill='%23b4452a'/%3E%3Ctext x='50' y='68' font-size='52' text-anchor='middle' fill='%23faf6ef' font-family='Georgia,serif'%3EG%3C/text%3E%3C/svg%3E" />

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Y6T24CCC58"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
      gtag('js', new Date());
      gtag('config', 'G-Y6T24CCC58');

      // Restore previous consent if stored
      const stored = localStorage.getItem('ga_cookie_consent');
      if (stored === 'granted') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Allura&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600;1,9..144,700&family=Public+Sans:ital,wght@0,400;0,500;0,600;1,400;1,500&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <Header lang={lang} />
    <main id="main" data-pagefind-body>
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieBanner
      lang={lang}
      banner={ui.footer.cookieBanner}
      accept={ui.footer.cookieAccept}
      decline={ui.footer.cookieDecline}
      privacyHref={localePath(lang, 'privacy')}
      privacyLabel={ui.footer.privacy}
    />
  </body>
</html>
