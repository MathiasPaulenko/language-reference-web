---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { sectionPath, withPinyin } from '../../../lib/utils';
import { getUI } from '../../../i18n';
import { interfaceLocales, type LocaleCode } from '../../../config/languages';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);

const allTopics = await getCollection('topics');
const published = allTopics
  .filter((t) => !t.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const diffStyles: Record<string, { bg: string; text: string; label: string }> = {
  beginner:    { bg: '#e8f5e9', text: '#2f7a6b', label: 'Beginner' },
  intermediate:{ bg: '#fff3e0', text: '#b4452a', label: 'Intermediate' },
  advanced:    { bg: '#ffebee', text: '#b4452a', label: 'Advanced' },
};
---

<BaseLayout title={`${ui.nav.topics} — ${ui.site.name}`} description={ui.topics.subtitle} lang={lang}>
  <section class="border-b border-line bg-[#2a2520]">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.nav.topics}</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">{ui.topics.title}</h1>
      <p class="mt-4 max-w-xl text-lg text-paper/70">{published.length} grammar concepts documented across Spanish, English, and Chinese.</p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24" id="topics-list">
    {/* Filters */}
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="relative max-w-md flex-1">
        <input
          type="text"
          id="topic-search"
          placeholder={ui.topics.filterSearch}
          class="w-full rounded-xl border border-line bg-paper px-4 py-2.5 pl-10 text-sm text-ink placeholder:text-ink-faint focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
        />
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
      <div class="flex flex-wrap gap-2" id="difficulty-filters">
        {[
          { key: 'all', label: ui.topics.filterAll },
          { key: 'beginner', label: ui.topics.filterBeginner },
          { key: 'intermediate', label: ui.topics.filterIntermediate },
          { key: 'advanced', label: ui.topics.filterAdvanced },
        ].map((btn) => (
          <button
            data-filter={btn.key}
            class={`filter-btn rounded-full border px-4 py-1.5 text-sm font-medium transition-all ${
              btn.key === 'all'
                ? 'border-accent bg-accent text-paper'
                : 'border-line bg-paper text-ink-soft hover:border-ink-faint hover:text-ink'
            }`}
          >
            {btn.label}
          </button>
        ))}
      </div>
    </div>

    <p class="mt-4 text-sm text-ink-faint" id="topics-count">{published.length} topics</p>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3" id="topics-grid">
      {
        published.map((topic, idx) => (
          <a
            href={sectionPath(lang, 'topics', topic.id)}
            class="topic-card group flex flex-col rounded-xl border border-line bg-paper p-7 transition-colors hover:bg-paper-deep"
            data-index={idx}
            data-difficulty={topic.data.difficulty}
            data-title={topic.data.title.toLowerCase()}
            data-desc={topic.data.description.toLowerCase()}
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-ink-faint">{String(idx + 1).padStart(2, '0')}</span>
              {topic.data.difficulty && (
                <span class="difficulty-badge rounded-full px-2.5 py-0.5 font-mono text-[10px] font-bold uppercase tracking-wider" style={`background:${diffStyles[topic.data.difficulty].bg};color:${diffStyles[topic.data.difficulty].text}`}>
                  {diffStyles[topic.data.difficulty].label}
                </span>
              )}
            </div>
            <h2 class="mt-4 font-display text-2xl font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
              {topic.data.title}
            </h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-soft" set:html={lang === 'zh' ? topic.data.description : withPinyin(topic.data.description)} />
            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-ink-faint transition-colors group-hover:text-accent">
              {ui.article.explanation}
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))
      }
    </div>

    <p class="mt-8 hidden text-center text-sm text-ink-faint" id="no-results">No topics match your search.</p>
  </section>

  <script>
    (function() {
      const searchInput = document.getElementById('topic-search');
      const filterBtns = document.querySelectorAll('.filter-btn');
      const grid = document.getElementById('topics-grid');
      const allCards = Array.from(document.querySelectorAll('.topic-card'));
      const countLabel = document.getElementById('topics-count');
      const noResults = document.getElementById('no-results');

      let activeFilter = 'all';

      function update() {
        const query = searchInput?.value.toLowerCase().trim() || '';

        const visible = allCards.filter((card) => {
          const diff = card.getAttribute('data-difficulty') || '';
          const title = card.getAttribute('data-title') || '';
          const desc = card.getAttribute('data-desc') || '';

          const matchesSearch = !query || title.includes(query) || desc.includes(query);
          const matchesLevel = activeFilter === 'all' || diff === activeFilter;
          return matchesSearch && matchesLevel;
        });

        visible.sort((a, b) => {
          return parseInt(a.getAttribute('data-index') || '0') - parseInt(b.getAttribute('data-index') || '0');
        });

        grid.innerHTML = '';
        visible.forEach((card) => grid.appendChild(card));

        if (countLabel) countLabel.textContent = visible.length + ' topics';
        if (noResults) noResults.classList.toggle('hidden', visible.length > 0);
      }

      searchInput?.addEventListener('input', update);

      filterBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          activeFilter = btn.getAttribute('data-filter') || 'all';

          filterBtns.forEach((b) => {
            const isActive = b.getAttribute('data-filter') === activeFilter;
            b.classList.toggle('border-accent', isActive);
            b.classList.toggle('bg-accent', isActive);
            b.classList.toggle('text-paper', isActive);
            b.classList.toggle('border-line', !isActive);
            b.classList.toggle('bg-paper', !isActive);
            b.classList.toggle('text-ink-soft', !isActive);
            b.classList.toggle('hover:border-ink-faint', !isActive);
            b.classList.toggle('hover:text-ink', !isActive);
          });

          update();
        });
      });
    })();
  </script>
</BaseLayout>
