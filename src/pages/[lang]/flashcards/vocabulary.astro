---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localePath, pageAlternates } from '../../../lib/utils';
import { getUI, languageName } from '../../../i18n';
import { interfaceLocales, analyzedLanguages, type LocaleCode } from '../../../config/languages';
import FlagIcon from '../../../components/astro/FlagIcon.astro';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
const alternates = pageAlternates('flashcards/vocabulary');

const allVocab = await getCollection('vocabulary');
const entry = allVocab.find((e) => e.data.title === 'Essential Words' && !e.data.draft);
const entries = entry?.data.entries ?? [];

interface Flashcard {
  id: number;
  front: string;
  back: string;
  language: string;
}

let idCounter = 0;
const cards: Flashcard[] = [];

entries.forEach((item) => {
  analyzedLanguages.forEach((l) => {
    const translation = item.translations[l.code];
    if (translation) {
      cards.push({
        id: idCounter++,
        front: item.word + (item.definition ? '\n' + item.definition : ''),
        back: translation,
        language: l.code,
      });
    }
  });
});

// Shuffle
for (let i = cards.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [cards[i], cards[j]] = [cards[j], cards[i]];
}
cards.forEach((c, i) => { c.id = i; });

const cardsJson = JSON.stringify(cards);
---

<BaseLayout
  title={`${ui.flashcards.vocabularyTitle} | ${ui.site.name}`}
  description={ui.flashcards.vocabularyMetaDesc.replace('{count}', String(cards.length))}
  lang={lang}
  alternates={alternates}
  jsonLd={{
    '@type': 'LearningResource',
    name: ui.flashcards.vocabularyTitle,
    description: ui.flashcards.vocabularyMetaDesc.replace('{count}', String(cards.length)),
    inLanguage: lang,
  }}
>
  {/* Hero */}
  <section class="border-b border-line bg-[#2a2520]">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.landing.flashcardsTitle}</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">{ui.flashcards.vocabularyTitle}</h1>
      <p class="mt-4 max-w-xl text-lg text-paper/70">{ui.flashcards.vocabularyMetaDesc.replace('{count}', String(cards.length))}</p>
    </div>
  </section>

  {/* Breadcrumb */}
  <nav aria-label="Breadcrumb" class="mx-auto mt-6 flex max-w-6xl items-center gap-2 px-5 text-xs text-ink-faint sm:px-8">
    <a href={localePath(lang)} class="transition-colors hover:text-accent">{ui.nav.home}</a>
    <span>/</span>
    <a href={localePath(lang, 'flashcards')} class="transition-colors hover:text-accent">{ui.nav.flashcards}</a>
    <span>/</span>
    <span class="text-ink-soft">{ui.nav.vocabulary}</span>
  </nav>

  {/* Controls */}
  <section class="mx-auto mt-8 max-w-4xl px-5 sm:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-wrap gap-2" id="lang-filters">
        <button data-lang="all" class="filter-btn rounded-full border border-accent bg-accent px-4 py-1.5 text-xs font-medium text-paper transition-all">{ui.flashcards.all}</button>
        {analyzedLanguages.map((l) => (
          <button data-lang={l.code} class="filter-btn rounded-full border border-line bg-paper px-4 py-1.5 text-xs font-medium text-ink-soft transition-all hover:border-accent hover:text-accent">
            <span class="flex items-center gap-1.5">
              <FlagIcon code={l.code} size={12} />
              {languageName(ui, l.code)}
            </span>
          </button>
        ))}
      </div>
      <p class="font-mono text-sm text-ink-faint" id="card-counter">{ui.flashcards.cardCounter.replace('{current}', '1').replace('{total}', String(cards.length))}</p>
    </div>
  </section>

  {/* Flashcard viewer */}
  <section class="mx-auto mt-8 max-w-2xl px-5 pb-16 sm:px-8">
    <div class="perspective-[1000px] w-full">
      <div id="flashcard" class="relative aspect-[4/3] w-full cursor-pointer rounded-2xl border-2 border-line bg-paper shadow-lg transition-all duration-500" style="transform-style: preserve-3d;">
        <div id="card-front" class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl bg-paper p-8" style="backface-visibility: hidden;">
          <span class="font-mono text-[10px] uppercase tracking-wider text-ink-faint" id="front-label">{ui.flashcards.word}</span>
          <p class="mt-4 text-center font-display text-2xl font-semibold text-ink sm:text-3xl" id="front-text">{ui.flashcards.loading}</p>
          <span class="mt-6 text-xs text-ink-faint">{ui.flashcards.clickToFlip}</span>
        </div>
        <div id="card-back" class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl bg-paper p-8" style="backface-visibility: hidden; transform: rotateY(180deg);">
          <span class="font-mono text-[10px] uppercase tracking-wider text-accent" id="back-label">{ui.flashcards.translation}</span>
          <p class="mt-4 text-center font-display text-2xl font-semibold text-ink sm:text-3xl" id="back-text">{ui.flashcards.loading}</p>
          <span class="mt-6 text-xs text-ink-faint">{ui.flashcards.clickToFlipBack}</span>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-center gap-4">
      <button id="btn-prev" class="flex h-12 w-12 items-center justify-center rounded-full border border-line bg-paper text-ink-soft transition-all hover:border-accent hover:text-accent" aria-label={ui.flashcards.previousCard}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="btn-flip" class="rounded-full bg-accent px-8 py-3 font-display text-sm font-semibold text-paper transition-all hover:bg-accent/90 hover:shadow-lg">{ui.flashcards.flip}</button>
      <button id="btn-next" class="flex h-12 w-12 items-center justify-center rounded-full border border-line bg-paper text-ink-soft transition-all hover:border-accent hover:text-accent" aria-label={ui.flashcards.nextCard}>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
    <p class="mt-4 text-center text-xs text-ink-faint">{ui.flashcards.keyboardHint}</p>
  </section>

  <script define:vars={{ cardsJson, uiJson: JSON.stringify({
    all: ui.flashcards.all,
    cardCounter: ui.flashcards.cardCounter,
    word: ui.flashcards.word,
    translation: ui.flashcards.translation,
    noCardsMatch: ui.flashcards.noCardsMatch,
    tryDifferentLanguage: ui.flashcards.tryDifferentLanguage,
    zeroCards: ui.flashcards.zeroCards,
    spanish: ui.languages.spanish,
    english: ui.languages.english,
    chinese: ui.languages.chinese,
  }) }}>
    const uiStr = JSON.parse(uiJson);
    const allCards = JSON.parse(cardsJson);
    let currentIdx = 0;
    let filteredCards = [...allCards];
    let isFlipped = false;

    const cardEl = document.getElementById('flashcard');
    const frontText = document.getElementById('front-text');
    const backText = document.getElementById('back-text');
    const frontLabel = document.getElementById('front-label');
    const backLabel = document.getElementById('back-label');
    const counterEl = document.getElementById('card-counter');
    const filterBtns = document.querySelectorAll('.filter-btn');

    function updateCard() {
      if (filteredCards.length === 0) {
        frontText.textContent = uiStr.noCardsMatch;
        backText.textContent = uiStr.tryDifferentLanguage;
        counterEl.textContent = uiStr.zeroCards;
        return;
      }
      const card = filteredCards[currentIdx];
      frontText.innerHTML = card.front.replace(/\n/g, '<br>');
      backText.innerHTML = card.back;
      frontLabel.textContent = uiStr.word;
      backLabel.textContent = languageLabel(card.language);
      counterEl.textContent = uiStr.cardCounter.replace('{current}', String(currentIdx + 1)).replace('{total}', String(filteredCards.length));
      isFlipped = false;
      cardEl.style.transform = '';
    }

    function languageLabel(code) {
      const labels = { spanish: uiStr.spanish, english: uiStr.english, chinese: uiStr.chinese };
      return labels[code] || code;
    }

    function flip() {
      isFlipped = !isFlipped;
      cardEl.style.transform = isFlipped ? 'rotateY(180deg)' : '';
    }

    function next() {
      if (filteredCards.length === 0) return;
      currentIdx = (currentIdx + 1) % filteredCards.length;
      updateCard();
    }

    function prev() {
      if (filteredCards.length === 0) return;
      currentIdx = (currentIdx - 1 + filteredCards.length) % filteredCards.length;
      updateCard();
    }

    function setFilter(langCode) {
      if (langCode === 'all') {
        filteredCards = [...allCards];
      } else {
        filteredCards = allCards.filter((c) => c.language === langCode);
      }
      currentIdx = 0;
      updateCard();
      filterBtns.forEach((btn) => {
        const isActive = btn.getAttribute('data-lang') === langCode;
        btn.classList.toggle('border-accent', isActive);
        btn.classList.toggle('bg-accent', isActive);
        btn.classList.toggle('text-paper', isActive);
        btn.classList.toggle('border-line', !isActive);
        btn.classList.toggle('bg-paper', !isActive);
        btn.classList.toggle('text-ink-soft', !isActive);
      });
    }

    cardEl?.addEventListener('click', flip);
    document.getElementById('btn-flip')?.addEventListener('click', flip);
    document.getElementById('btn-next')?.addEventListener('click', next);
    document.getElementById('btn-prev')?.addEventListener('click', prev);

    document.addEventListener('keydown', (e) => {
      if (e.key === ' ' || e.key === 'Spacebar') { e.preventDefault(); flip(); }
      else if (e.key === 'ArrowRight') { next(); }
      else if (e.key === 'ArrowLeft') { prev(); }
    });

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => { setFilter(btn.getAttribute('data-lang')); });
    });

    updateCard();
  </script>
</BaseLayout>
