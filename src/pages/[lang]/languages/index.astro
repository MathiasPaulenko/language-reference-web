---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localePath, sectionPath, indexAlternates } from '../../../lib/utils';
import { getUI, languageName } from '../../../i18n';
import { interfaceLocales, analyzedLanguages, type LocaleCode } from '../../../config/languages';
import FlagIcon from '../../../components/astro/FlagIcon.astro';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
const alternates = indexAlternates('languages');

const languageFacts = {
  spanish: {
    speakers: '500M+',
    countries: '21',
    gender: 'Yes',
    cases: 'No',
    wordOrder: 'SVO / VSO',
    desc: 'A Romance language with rich verb conjugation, grammatical gender, and a transparent spelling system.',
  },
  english: {
    speakers: '1.5B+',
    countries: '67',
    gender: 'No',
    cases: 'Only pronouns',
    wordOrder: 'Strict SVO',
    desc: 'A Germanic language with minimal inflection, analytical structure, and the largest vocabulary of any language.',
  },
  chinese: {
    speakers: '1.1B+',
    countries: '3',
    gender: 'No',
    cases: 'No',
    wordOrder: 'SVO + topic',
    desc: 'A Sino-Tibetan language with tones, characters, measure words, and no grammatical gender or verb conjugation.',
  },
};
---

<BaseLayout
  title={`${ui.landing.languagesTitle} | ${ui.site.name}`}
  description={ui.landing.languagesDesc}
  lang={lang}
  alternates={alternates}
  jsonLd={{
    '@type': 'WebPage',
    name: ui.landing.languagesTitle,
    description: ui.landing.languagesDesc,
    inLanguage: lang,
  }}
>
  <section class="border-b border-line bg-[#2a2520]">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.landing.languagesTitle}</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">{ui.landing.languagesSubtitle}</h1>
      <p class="mt-4 max-w-xl text-lg text-paper/70">{ui.landing.languagesDesc}</p>
    </div>
  </section>

  <section class="border-y border-line bg-paper-deep">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.landing.methodLabel}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.howLanguagesTitle}</h2>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink-soft">{ui.landing.languagesDesc}</p>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { num: '01', title: ui.landing.howLanguages1Title, body: ui.landing.howLanguages1Body },
          { num: '02', title: ui.landing.howLanguages2Title, body: ui.landing.howLanguages2Body },
          { num: '03', title: ui.landing.howLanguages3Title, body: ui.landing.howLanguages3Body },
          { num: '04', title: ui.landing.howLanguages4Title, body: ui.landing.howLanguages4Body },
        ].map((step, i, arr) => (
          <div class="group relative flex flex-col rounded-2xl border border-line bg-paper p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10 font-mono text-sm font-bold text-accent transition-colors group-hover:bg-accent group-hover:text-paper">
                {step.num}
              </span>
              {i < arr.length - 1 && (
                <div class="hidden lg:block absolute top-10 left-full h-px w-6 border-t-2 border-dashed border-accent/20" />
              )}
            </div>
            <h3 class="mt-5 font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
              {step.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-soft">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.landing.chooseLanguage}</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.grammarByLanguage}</h2>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {analyzedLanguages.map((l) => {
        const facts = languageFacts[l.code as keyof typeof languageFacts];
        return (
          <a href={sectionPath(lang, 'languages', l.code)} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:shadow-lg hover:border-accent/20">
            {/* Color bar */}
            <div class="h-1.5 w-full" style={`background:${l.color}`} />
            <div class="flex flex-1 flex-col p-8">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-full" style={`background:${l.color}15`}>
                  <FlagIcon code={l.code} size={20} />
                </span>
                <div>
                  <h3 class="font-display text-2xl font-semibold tracking-tight text-ink">{languageName(ui, l.code)}</h3>
                  <p class="font-mono text-xs uppercase tracking-wider text-ink-faint">{l.code}</p>
                </div>
              </div>
              <p class="mt-4 flex-1 text-sm leading-relaxed text-ink-soft">{l.code === 'spanish' ? ui.landing.spanishDesc : l.code === 'english' ? ui.landing.englishDesc : ui.landing.chineseDesc}</p>

              {/* Fact grid - revealed on hover */}
              <div class="mt-5 grid grid-cols-2 gap-3 rounded-xl bg-paper-deep p-4 opacity-60 transition-opacity group-hover:opacity-100">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-wider text-ink-faint">{ui.landing.speakers}</p>
                  <p class="mt-0.5 font-display text-sm font-semibold text-ink">{facts.speakers}</p>
                </div>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-wider text-ink-faint">{ui.landing.countries}</p>
                  <p class="mt-0.5 font-display text-sm font-semibold text-ink">{facts.countries}</p>
                </div>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-wider text-ink-faint">{ui.landing.gender}</p>
                  <p class="mt-0.5 font-display text-sm font-semibold text-ink">{facts.gender}</p>
                </div>
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-wider text-ink-faint">{ui.landing.cases}</p>
                  <p class="mt-0.5 font-display text-sm font-semibold text-ink">{facts.cases}</p>
                </div>
                <div class="col-span-2">
                  <p class="font-mono text-[10px] uppercase tracking-wider text-ink-faint">{ui.landing.wordOrder}</p>
                  <p class="mt-0.5 font-display text-sm font-semibold text-ink">{facts.wordOrder}</p>
                </div>
              </div>

              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-ink-faint transition-colors group-hover:text-accent">
                {ui.landing.exploreGrammarTopics} <span class="transition-transform group-hover:translate-x-1">→</span>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
