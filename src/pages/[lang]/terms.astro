---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';
import { pageAlternates } from '../../lib/utils';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
const alternates = pageAlternates('terms');
---

<BaseLayout
  title={`${ui.footer.terms} | ${ui.site.name}`}
  description={ui.legal.termsDesc}
  lang={lang}
  alternates={alternates}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.legal.label}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.footer.terms}</h1>
    <div class="mt-8 space-y-6 leading-relaxed text-ink-soft">
      <p>{ui.legal.termsDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.termsUseTitle}</h2>
      <p>{ui.legal.termsUseDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.termsWarrantyTitle}</h2>
      <p>{ui.legal.termsWarrantyDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.termsLiabilityTitle}</h2>
      <p>{ui.legal.termsLiabilityDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.termsChangesTitle}</h2>
      <p>{ui.legal.termsChangesDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.termsLawTitle}</h2>
      <p>{ui.legal.termsLawDesc}</p>
    </div>
  </main>
</BaseLayout>
