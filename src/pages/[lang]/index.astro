---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localePath, sectionPath, withPinyin, pageAlternates } from '../../lib/utils';
import { getUI, languageName } from '../../i18n';
import {
  interfaceLocales,
  analyzedLanguages,
  type LocaleCode,
} from '../../config/languages';
import FlagIcon from '../../components/astro/FlagIcon.astro';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
const alternates = pageAlternates('');

const allTopics = await getCollection('topics');
// Group by topic field, prefer current locale with fallback to 'en'
const topicsByTopic = new Map();
for (const t of allTopics.filter((t) => !t.data.draft)) {
  const topicKey = t.data.topic;
  const existing = topicsByTopic.get(topicKey);
  if (!existing) {
    topicsByTopic.set(topicKey, t);
  } else if (t.data.locale === lang) {
    topicsByTopic.set(topicKey, t);
  } else if (t.data.locale === 'en' && existing.data.locale !== lang) {
    topicsByTopic.set(topicKey, t);
  }
}
const topics = Array.from(topicsByTopic.values())
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const allVocab = await getCollection('vocabulary');
const vocabStats = allVocab.reduce(
  (acc, v) => {
    const slug = v.id.replace(/\\.mdx$/, '').replace(/\\.\\w+$/, '');
    const count = v.data.entries?.length ?? 0;
    if (slug === 'words') acc.words = count;
    else if (slug === 'phrases') acc.phrases = count;
    else if (slug === 'expressions') acc.expressions = count;
    return acc;
  },
  { words: 0, phrases: 0, expressions: 0 }
);

const legend = analyzedLanguages.map((l) => ({
  code: l.code,
  name: languageName(ui, l.code),
  color: l.color,
}));

const comparisonRows: { concept: string; values: Record<string, string> }[] = [
  { concept: 'Definite', values: { spanish: 'el libro', english: 'the book', chinese: '<ruby>这<rt>zhè</rt></ruby><ruby>本<rt>běn</rt></ruby><ruby>书<rt>shū</rt></ruby>' } },
  { concept: 'Indefinite', values: { spanish: 'un libro', english: 'a book', chinese: '<ruby>一<rt>yì</rt></ruby><ruby>本<rt>běn</rt></ruby><ruby>书<rt>shū</rt></ruby>' } },
  { concept: 'Plural', values: { spanish: 'los libros', english: 'the books', chinese: '<ruby>这<rt>zhè</rt></ruby><ruby>些<rt>xiē</rt></ruby><ruby>书<rt>shū</rt></ruby>' } },
  { concept: 'Generic', values: { spanish: 'los gatos', english: 'cats', chinese: '<ruby>猫<rt>māo</rt></ruby>' } },
  { concept: 'Zero article', values: { spanish: 'Ø agua', english: 'water', chinese: '<ruby>水<rt>shuǐ</rt></ruby>' } },
];

const steps = [
  { num: '01', title: ui.howItWorks.step1Title, body: ui.howItWorks.step1Body },
  { num: '02', title: ui.howItWorks.step2Title, body: ui.howItWorks.step2Body },
  { num: '03', title: ui.howItWorks.step3Title, body: ui.howItWorks.step3Body },
  { num: '04', title: ui.howItWorks.step4Title, body: ui.howItWorks.step4Body },
];
---

<BaseLayout
  title={ui.site.name}
  description={ui.hero.body}
  lang={lang}
  alternates={alternates}
  jsonLd={[
    {
      '@type': 'WebSite',
      name: ui.site.name,
      description: ui.site.tagline,
      url: Astro.site ? new URL(localePath(lang), Astro.site).toString() : undefined,
      inLanguage: lang,
      publisher: {
        '@type': 'Organization',
        name: ui.site.name,
        url: 'https://grammarnavigator.com',
        logo: 'https://grammarnavigator.com/favicon.svg',
      },
    },
    {
      '@type': 'Organization',
      name: ui.site.name,
      url: 'https://grammarnavigator.com',
      logo: 'https://grammarnavigator.com/favicon.svg',
      sameAs: [],
      description: ui.site.tagline,
    },
  ]}
>
  <section class="relative overflow-hidden border-b border-line bg-gradient-to-br from-[#ece3d0] via-[#f1ead8] to-[#e2d6c2]">
    <div class="hero-typo-bg">
      <!-- 30 normal letters (75%) -->
      <span class="typo-particle typo-particle--xl" aria-hidden="true">A</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">g</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">r</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">m</span>
      <span class="typo-particle" aria-hidden="true">M</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">a</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">n</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">L</span>
      <span class="typo-particle" aria-hidden="true">y</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">i</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">d</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">O</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">e</span>
      <span class="typo-particle" aria-hidden="true">P</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">a</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">g</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">e</span>
      <span class="typo-particle" aria-hidden="true">s</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">t</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">ñ</span>
      <span class="typo-particle" aria-hidden="true">ü</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">á</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">ó</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">ç</span>
      <span class="typo-particle" aria-hidden="true">l</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">ú</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">é</span>
      <span class="typo-particle" aria-hidden="true">à</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">b</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">h</span>
      <!-- 8 Chinese characters (20%) -->
      <span class="typo-particle typo-particle--xl" aria-hidden="true">文</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">的</span>
      <span class="typo-particle" aria-hidden="true">法</span>
      <span class="typo-particle typo-particle--lg" aria-hidden="true">语</span>
      <span class="typo-particle typo-particle--sm" aria-hidden="true">词</span>
      <span class="typo-particle typo-particle--xl" aria-hidden="true">写</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">读</span>
      <span class="typo-particle" aria-hidden="true">学</span>
      <!-- 2 special characters (5%) -->
      <span class="typo-particle typo-particle--xl" aria-hidden="true">?</span>
      <span class="typo-particle typo-particle--xs" aria-hidden="true">…</span>
    </div>
    <div class="relative z-10 mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="reveal font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent" style="animation-delay:0ms">
        {ui.hero.eyebrow}
      </p>
      <h1
        class="reveal mt-6 max-w-4xl flex flex-col leading-[1.1] tracking-tight"
        style="animation-delay:80ms"
      >
        <span class="font-script text-5xl text-ink sm:text-6xl lg:text-7xl">
          {ui.hero.titleLine1}
        </span>
        <span class="-mt-1 font-body text-4xl font-medium text-ink sm:text-5xl lg:text-6xl">
          {ui.hero.titleLine2}
        </span>
        <span class="mt-1 font-display text-3xl font-bold text-accent sm:text-4xl lg:text-5xl">
          {ui.hero.titleLine3}
        </span>
      </h1>
      <p class="reveal mt-6 max-w-2xl text-lg leading-relaxed text-ink-soft" style="animation-delay:160ms">
        {ui.hero.body}
      </p>

      <div class="reveal mt-8 flex flex-wrap items-center gap-4" style="animation-delay:240ms">
        <a
          href={sectionPath(lang, 'topics')}
          class="group inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-semibold text-paper transition-transform hover:-translate-y-0.5"
        >
          {ui.hero.ctaPrimary}
          <span class="transition-transform group-hover:translate-x-1">→</span>
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center gap-2 rounded-full border border-ink px-6 py-3 text-sm font-semibold text-ink transition-colors hover:bg-ink hover:text-paper"
        >
          {ui.hero.ctaSecondary}
        </a>
      </div>

      <div class="reveal mt-10 flex flex-wrap items-center gap-4" style="animation-delay:320ms">
        {
          legend.map((l) => (
            <span class="group flex items-center transition-transform duration-300 hover:scale-110" aria-label={l.name}>
              <FlagIcon code={l.code} size={28} />
            </span>
          ))
        }
      </div>
    </div>
  </section>

  {/* Stats bar */}
  <section class="border-b border-line bg-paper-darker">
    <div class="mx-auto max-w-6xl px-5 py-10 sm:px-8 sm:py-14">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.stats.label}</p>
      <div class="mt-8 grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-5">
        <div class="text-center">
          <span class="font-display text-4xl font-semibold tracking-tight text-ink">{topics.length}</span>
          <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-faint">{ui.stats.grammarTopics}</p>
        </div>
        <div class="text-center">
          <span class="font-display text-4xl font-semibold tracking-tight text-ink">{vocabStats.words}</span>
          <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-faint">{ui.stats.words}</p>
        </div>
        <div class="text-center">
          <span class="font-display text-4xl font-semibold tracking-tight text-ink">{vocabStats.phrases}</span>
          <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-faint">{ui.stats.phrases}</p>
        </div>
        <div class="text-center">
          <span class="font-display text-4xl font-semibold tracking-tight text-ink">{vocabStats.expressions}</span>
          <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-faint">{ui.stats.expressions}</p>
        </div>
        <div class="text-center">
          <span class="font-display text-4xl font-semibold tracking-tight text-ink">{analyzedLanguages.length}</span>
          <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink-faint">{ui.stats.languagesAnalyzed}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.grammar}</p>
        <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.grammarTitle}</h2>
        <p class="mt-3 max-w-xl text-ink-soft">{ui.landing.grammarDesc}</p>
      </div>
    </div>

    <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2 lg:grid-cols-3">
      {
        topics.slice(0, 8).map((topic, i) => (
          <a
            href={sectionPath(lang, 'topics', topic.data.topic)}
            class="group flex flex-col bg-paper p-7 transition-colors hover:bg-paper-deep"
          >
            <span class="font-mono text-xs text-ink-faint">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="mt-4 font-display text-2xl font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
              {topic.data.title}
            </h3>
            <p class="mt-2 flex-1 break-words text-sm leading-relaxed text-ink-soft" set:html={lang === 'zh' ? topic.data.description : withPinyin(topic.data.description)} />
            <span class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-ink-faint transition-colors group-hover:text-accent">
              {ui.article.explanation}
              <span class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))
      }
      <a
        href={sectionPath(lang, 'topics')}
        class="group flex flex-col items-center justify-center bg-paper-deep p-7 transition-colors hover:bg-accent/5"
      >
        <span class="font-display text-lg font-semibold text-ink transition-colors group-hover:text-accent">
          {ui.topics.viewAll}
        </span>
        <span class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-accent transition-transform group-hover:translate-x-1">
          →
        </span>
      </a>
    </div>
  </section>

  <section class="border-y border-line bg-paper-deep">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.languages}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.languagesTitle}</h2>
      <p class="mt-3 max-w-xl text-ink-soft">{ui.landing.languagesDesc}</p>

      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {
          analyzedLanguages.map((l) => (
            <a
              href={sectionPath(lang, 'languages', l.code)}
              class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg"
            >
              <div class="h-1.5 w-full" style={`background:${l.color}`} />
              <div class="flex flex-1 flex-col p-8">
                <div class="flex items-center gap-3">
                  <span class="flex h-10 w-10 items-center justify-center rounded-full" style={`background:${l.color}15`}>
                    <FlagIcon code={l.code} size={20} />
                  </span>
                  <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{languageName(ui, l.code)}</h3>
                </div>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">
                  {ui.languages.heroDesc.replace('{language}', languageName(ui, l.code)).replace('{count}', String(topics.length))}
                </p>
                <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
                  {ui.languages.grammarSuffix}
                  <span class="transition-transform group-hover:translate-x-1">→</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.vocabulary}</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.vocabularyTitle}</h2>
    <p class="mt-3 max-w-xl text-ink-soft">{ui.landing.vocabularyDesc}</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <a href={localePath(lang, 'vocabulary/words')} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg">
        <div class="h-1.5 w-full bg-[#3b6ea5]" />
        <div class="flex flex-1 flex-col p-8">
          <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{ui.nav.words}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{ui.landing.vocabWordsDesc}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
            {ui.landing.explore}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
      <a href={localePath(lang, 'vocabulary/phrases')} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg">
        <div class="h-1.5 w-full bg-[#b4452a]" />
        <div class="flex flex-1 flex-col p-8">
          <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{ui.nav.phrases}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{ui.landing.vocabPhrasesDesc}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
            {ui.landing.explore}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
      <a href={localePath(lang, 'vocabulary/expressions')} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg">
        <div class="h-1.5 w-full bg-[#2f7a6b]" />
        <div class="flex flex-1 flex-col p-8">
          <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{ui.nav.expressions}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{ui.landing.vocabExpressionsDesc}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
            {ui.landing.explore}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
    </div>
  </section>

  <section class="border-y border-line bg-paper-deep">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.learningPaths}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.learningPathsTitle}</h2>
      <p class="mt-3 max-w-xl text-ink-soft">{ui.landing.learningPathsDesc}</p>

      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {
          analyzedLanguages.map((l) => (
            <a
              href={localePath(lang, `learning-paths/${l.code}`)}
              class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg"
            >
              <div class="h-1.5 w-full" style={`background:${l.color}`} />
              <div class="flex flex-1 flex-col p-8">
                <div class="flex items-center gap-3">
                  <span class="flex h-10 w-10 items-center justify-center rounded-full" style={`background:${l.color}15`}>
                    <FlagIcon code={l.code} size={20} />
                  </span>
                  <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{languageName(ui, l.code)}</h3>
                </div>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">
                  {ui.learningPaths.heroDesc}
                </p>
                <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
                  {ui.learningPaths.learn}
                  <span class="transition-transform group-hover:translate-x-1">→</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.nav.flashcards}</p>
    <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.landing.flashcardsTitle}</h2>
    <p class="mt-3 max-w-xl text-ink-soft">{ui.landing.flashcardsDesc}</p>

    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      <a href={localePath(lang, 'flashcards/grammar')} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg">
        <div class="h-1.5 w-full bg-accent" />
        <div class="flex flex-1 flex-col p-8">
          <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{ui.nav.grammar}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{ui.landing.flashcardsGrammarDesc}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
            {ui.landing.startDeck}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
      <a href={localePath(lang, 'flashcards/vocabulary')} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg">
        <div class="h-1.5 w-full bg-[#3b6ea5]" />
        <div class="flex flex-1 flex-col p-8">
          <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{ui.nav.vocabulary}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{ui.landing.flashcardsVocabDesc}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
            {ui.landing.startDeck}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
      <a href={localePath(lang, 'flashcards/phrases')} class="group relative flex flex-col overflow-hidden rounded-2xl border border-line bg-paper transition-all hover:-translate-y-1 hover:border-accent/20 hover:shadow-lg">
        <div class="h-1.5 w-full bg-[#2f7a6b]" />
        <div class="flex flex-1 flex-col p-8">
          <h3 class="font-display text-xl font-semibold tracking-tight text-ink">{ui.nav.phrases}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">{ui.landing.flashcardsPhrasesDesc}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent">
            {ui.landing.startDeck}
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
    </div>
  </section>

  <section id="how-it-works" class="border-y border-line bg-paper-deep">
    <div class="mx-auto max-w-6xl px-5 py-20 sm:px-8 sm:py-28">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.landing.methodLabel}</p>
      <h2 class="mt-3 font-display text-3xl font-semibold tracking-tight sm:text-4xl">{ui.howItWorks.title}</h2>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink-soft">{ui.howItWorks.intro}</p>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, i) => (
            <div class="group relative flex flex-col rounded-2xl border border-line bg-paper p-6 transition-all duration-300 hover:-translate-y-1 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/5">
              <div class="flex items-center gap-3">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10 font-mono text-sm font-bold text-accent transition-colors group-hover:bg-accent group-hover:text-paper">
                  {step.num}
                </span>
                {i < steps.length - 1 && (
                  <div class="hidden lg:block absolute top-10 left-full h-px w-6 border-t-2 border-dashed border-accent/20" />
                )}
              </div>
              <h3 class="mt-5 font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-accent">
                {step.title}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink-soft">{step.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
