---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getUI } from '../../../i18n';
import { interfaceLocales, type LocaleCode } from '../../../config/languages';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);
---

<BaseLayout title={`${ui.nav.guides} — ${ui.site.name}`} description={ui.site.tagline} lang={lang}>
  <section class="border-b border-line bg-[#2a2520]">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.nav.guides}</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">{ui.nav.guides}</h1>
      <p class="mt-4 max-w-xl text-lg text-paper/70">Audience-oriented guides for learners and teachers.</p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
    <div class="rounded-2xl border border-line bg-paper p-12 text-center">
      <p class="text-ink-faint">Guides will appear here as content is added.</p>
    </div>
  </section>
</BaseLayout>
