---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';
import { pageAlternates } from '../../lib/utils';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
const alternates = pageAlternates('disclaimer');
---

<BaseLayout
  title={`${ui.nav.disclaimer} | ${ui.site.name}`}
  description={ui.legal.disclaimerDesc}
  lang={lang}
  alternates={alternates}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.legal.label}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.nav.disclaimer}</h1>
    <div class="mt-8 space-y-6 leading-relaxed text-ink-soft">
      <p>{ui.legal.disclaimerDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.disclaimerAdviceTitle}</h2>
      <p>{ui.legal.disclaimerAdviceDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.disclaimerLinksTitle}</h2>
      <p>{ui.legal.disclaimerLinksDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.disclaimerErrorsTitle}</h2>
      <p>{ui.legal.disclaimerErrorsDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.disclaimerIptitle}</h2>
      <p>{ui.legal.disclaimerIpDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.disclaimerDmcaTitle}</h2>
      <p>{ui.legal.disclaimerDmcaDesc}</p>
      <h2 class="mt-8 font-display text-2xl font-semibold tracking-tight text-ink">{ui.legal.disclaimerAccuracyTitle}</h2>
      <p>{ui.legal.disclaimerAccuracyDesc}</p>
    </div>
  </main>
</BaseLayout>
