---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { localePath, withPinyin } from '../../../lib/utils';
import { getUI, languageName } from '../../../i18n';
import { interfaceLocales, analyzedLanguages, type LocaleCode, type AnalyzedLanguageCode } from '../../../config/languages';
import FlagIcon from '../../../components/astro/FlagIcon.astro';

export const getStaticPaths = (() =>
  interfaceLocales.map((locale) => ({
    params: { lang: locale.code },
  }))) satisfies GetStaticPaths;

const lang = Astro.params.lang as LocaleCode;
const ui = getUI(lang);

const allEntries = await getCollection('vocabulary');
const entry = allEntries.find((e) => e.data.title === 'Essential Words');

if (!entry) {
  throw new Error('Essential Words vocabulary entry not found');
}

const vocabData = entry.data;
const totalPages = Math.ceil((vocabData.entries || []).length / 20);

function range(start: number, end: number) {
  const out = [];
  for (let i = start; i <= end; i++) out.push(i);
  return out;
}

function getPageItems(currentPage: number) {
  if (totalPages <= 7) return range(0, totalPages - 1).map(p => ({ type: 'page', value: p }));
  if (currentPage <= 3) {
    return [...range(0, 4).map(p => ({ type: 'page' as const, value: p })), { type: 'gap' as const, value: -1 }, { type: 'page' as const, value: totalPages - 1 }];
  }
  if (currentPage >= totalPages - 4) {
    return [{ type: 'page' as const, value: 0 }, { type: 'gap' as const, value: -1 }, ...range(totalPages - 5, totalPages - 1).map(p => ({ type: 'page' as const, value: p }))];
  }
  return [
    { type: 'page' as const, value: 0 },
    { type: 'gap' as const, value: -1 },
    ...range(currentPage - 2, currentPage + 2).map(p => ({ type: 'page' as const, value: p })),
    { type: 'gap' as const, value: -1 },
    { type: 'page' as const, value: totalPages - 1 },
  ];
}

const initialPageItems = getPageItems(0);
---

<BaseLayout
  title={`${vocabData.title} — ${ui.site.name}`}
  description={vocabData.description}
  lang={lang}
>
  {/* Hero */}
  <section class="border-b border-line bg-[#2a2520]">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent">{ui.nav.vocabulary}</p>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-semibold tracking-tight text-paper sm:text-5xl">{vocabData.title}</h1>
      <p class="mt-4 max-w-xl text-lg text-paper/70">{vocabData.description}</p>
    </div>
  </section>

  {/* Breadcrumb */}
  <nav aria-label="Breadcrumb" class="mx-auto mt-6 flex max-w-6xl items-center gap-2 px-5 text-xs text-ink-faint sm:px-8">
    <a href={localePath(lang)} class="transition-colors hover:text-accent">{ui.nav.home}</a>
    <span>/</span>
    <a href={localePath(lang, 'vocabulary')} class="transition-colors hover:text-accent">{ui.nav.vocabulary}</a>
    <span>/</span>
    <span class="text-ink-soft">{vocabData.title}</span>
  </nav>

  {/* Language Selector */}
  <div class="mx-auto mt-8 max-w-6xl rounded-2xl border border-line bg-paper-deep p-5 shadow-sm sm:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.comparisons.compareLanguages}</p>
      <div class="flex gap-2">
        <button id="lang-select-all" class="rounded-full border border-line bg-paper px-3 py-1 text-xs font-medium text-ink-soft transition-colors hover:border-accent hover:text-accent">{ui.comparisons.selectAll}</button>
        <button id="lang-deselect-all" class="rounded-full border border-line bg-paper px-3 py-1 text-xs font-medium text-ink-soft transition-colors hover:border-accent hover:text-accent">{ui.comparisons.deselectAll}</button>
      </div>
    </div>
    <div class="mt-4 flex flex-wrap gap-2" id="lang-selector">
      {analyzedLanguages.map((l) => (
        <button
          type="button"
          class="lang-chip rounded-full border border-line bg-paper px-4 py-2 text-sm font-medium text-ink-soft transition-all hover:border-accent/30"
          data-lang={l.code}
          data-checked="true"
          aria-pressed="true"
        >
          <span class="flex items-center gap-2">
            <FlagIcon code={l.code} size={14} />
            {languageName(ui, l.code)}
            <span class="chip-check ml-0.5 h-3.5 w-3.5 text-current opacity-100 transition-opacity" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
            </span>
          </span>
        </button>
      ))}
    </div>
  </div>

  {/* Vocabulary Table */}
  {vocabData.entries && vocabData.entries.length > 0 && (
    <section class="mx-auto mb-16 mt-12 max-w-6xl px-5 sm:px-8" id="vocab-table">
      <div class="flex items-center gap-3">
        <span class="h-6 w-1 flex-shrink-0 rounded-full bg-accent" />
        <h2 class="font-display text-2xl font-semibold tracking-tight text-ink">{vocabData.title}</h2>
      </div>

      <div class="mt-6 overflow-hidden rounded-2xl border border-line bg-paper shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-line bg-paper-deep">
              <th class="px-5 py-3 text-left font-mono text-xs font-bold uppercase tracking-wider text-ink-faint">{ui.vocabulary.word}</th>
              {analyzedLanguages.map((l) => (
                <th class="vocab-col px-5 py-3 text-left font-mono text-xs font-bold uppercase tracking-wider text-ink-faint" data-lang={l.code}>
                  <span class="inline-flex items-center gap-1.5">
                    <FlagIcon code={l.code} size={12} />
                    {languageName(ui, l.code)}
                  </span>
                </th>
              ))}
              <th class="px-5 py-3 text-left font-mono text-xs font-bold uppercase tracking-wider text-ink-faint">{ui.vocabulary.definition}</th>
            </tr>
          </thead>
          <tbody>
            {vocabData.entries.map((item, idx) => (
              <tr class="vocab-row border-b border-line transition-colors hover:bg-paper-deep/50" data-page={Math.floor(idx / 20)}>
                <td class="px-5 py-4 font-display text-base font-semibold text-ink">{item.word}</td>
                {analyzedLanguages.map((l) => (
                  <td class="vocab-col px-5 py-4 text-ink-soft" data-lang={l.code} set:html={withPinyin(item.translations[l.code] || '—')} />
                ))}
                <td class="px-5 py-4 text-ink-faint">{item.definition}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* Pagination */}
      <nav aria-label="Pagination" class="mt-6 flex items-center justify-between" id="pagination">
        <button id="page-prev" class="rounded-full border border-line bg-paper px-4 py-2 text-sm font-medium text-ink-soft transition-colors hover:border-accent hover:text-accent disabled:opacity-30 disabled:cursor-not-allowed">{ui.vocabulary.previous}</button>
        <div id="page-numbers" class="flex items-center gap-1">
          {initialPageItems.map((item) => (
            item.type === 'gap'
              ? <span class="page-gap px-1.5 text-sm text-ink-faint">...</span>
              : <button class="page-num rounded-full border border-line bg-paper px-3.5 py-2 text-sm font-medium text-ink-soft transition-colors hover:border-accent hover:text-accent" data-page={item.value}>{item.value + 1}</button>
          ))}
        </div>
        <button id="page-next" class="rounded-full border border-line bg-paper px-4 py-2 text-sm font-medium text-ink-soft transition-colors hover:border-accent hover:text-accent disabled:opacity-30 disabled:cursor-not-allowed">{ui.vocabulary.next}</button>
      </nav>
    </section>
  )}

  {/* Empty state */}
  <div id="vocab-empty" class="mx-auto mb-16 mt-12 hidden max-w-6xl rounded-2xl border border-line bg-paper-deep p-8 px-5 text-center sm:px-8">
    <p class="text-sm text-ink-faint">{ui.comparisons.selectLanguageToView}</p>
  </div>

  <script is:inline>
    (function() {
      // --- Query elements ---
      var chips = document.querySelectorAll('.lang-chip');
      var selectAllBtn = document.getElementById('lang-select-all');
      var deselectAllBtn = document.getElementById('lang-deselect-all');
      var cols = document.querySelectorAll('.vocab-col');
      var table = document.getElementById('vocab-table');
      var empty = document.getElementById('vocab-empty');
      var rows = document.querySelectorAll('.vocab-row');
      var prevBtn = document.getElementById('page-prev');
      var nextBtn = document.getElementById('page-next');
      var pageContainer = document.getElementById('page-numbers');
      var perPage = 20;
      var totalPages = Math.ceil(rows.length / perPage);
      var currentPage = 0;

      // --- Helpers ---
      function isChecked(el) { return el.getAttribute('data-checked') === 'true'; }
      function setChecked(el, v) { el.setAttribute('data-checked', String(v)); el.setAttribute('aria-pressed', String(v)); }

      function range(a, b) { var o = []; for (var i = a; i <= b; i++) o.push(i); return o; }

      function getPageItems() {
        if (totalPages <= 7) return range(0, totalPages - 1);
        if (currentPage <= 3) return range(0, 4).concat([-1, totalPages - 1]);
        if (currentPage >= totalPages - 4) return [0, -1].concat(range(totalPages - 5, totalPages - 1));
        return [0, -1].concat(range(currentPage - 2, currentPage + 2)).concat([-1, totalPages - 1]);
      }

      function renderButtons() {
        if (!pageContainer) return;
        var items = getPageItems();
        var html = '';
        for (var i = 0; i < items.length; i++) {
          var p = items[i];
          if (p === -1) {
            html += '<span class="page-gap px-1.5 text-sm text-ink-faint">...</span>';
          } else {
            var activeCls = p === currentPage ? 'border-accent text-accent' : 'border-line text-ink-soft';
            html += '<button class="page-num rounded-full border bg-paper px-3.5 py-2 text-sm font-medium transition-colors hover:border-accent hover:text-accent ' + activeCls + '" data-page="' + p + '">' + (p + 1) + '</button>';
          }
        }
        pageContainer.innerHTML = html;
        var btns = pageContainer.querySelectorAll('.page-num');
        for (var j = 0; j < btns.length; j++) {
          (function(btn) {
            btn.addEventListener('click', function() {
              showPage(parseInt(btn.getAttribute('data-page'), 10));
            });
          })(btns[j]);
        }
      }

      function showPage(page) {
        currentPage = page;
        for (var i = 0; i < rows.length; i++) {
          var rp = parseInt(rows[i].getAttribute('data-page'), 10);
          rows[i].style.display = (rp === currentPage) ? '' : 'none';
        }
        renderButtons();
        if (prevBtn) prevBtn.disabled = currentPage === 0;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages - 1;
      }

      function updateLangFilter() {
        var active = {};
        for (var i = 0; i < chips.length; i++) {
          if (isChecked(chips[i])) active[chips[i].getAttribute('data-lang')] = true;
        }

        for (var i = 0; i < chips.length; i++) {
          var check = chips[i].querySelector('.chip-check');
          if (isChecked(chips[i])) {
            chips[i].classList.add('border-accent', 'text-accent');
            chips[i].classList.remove('border-line', 'text-ink-soft');
            if (check) check.classList.remove('opacity-0');
          } else {
            chips[i].classList.remove('border-accent', 'text-accent');
            chips[i].classList.add('border-line', 'text-ink-soft');
            if (check) check.classList.add('opacity-0');
          }
        }

        for (var i = 0; i < cols.length; i++) {
          var lang = cols[i].getAttribute('data-lang');
          cols[i].style.display = active[lang] ? '' : 'none';
        }

        var hasLang = Object.keys(active).length > 0;
        if (!hasLang) {
          if (table) table.classList.add('hidden');
          if (empty) empty.classList.remove('hidden');
        } else {
          if (table) table.classList.remove('hidden');
          if (empty) empty.classList.add('hidden');
        }
      }

      // --- Event listeners ---
      for (var i = 0; i < chips.length; i++) {
        chips[i].addEventListener('click', function(e) {
          e.stopPropagation();
          var lang = this.getAttribute('data-lang');
          var newState = !isChecked(this);
          for (var j = 0; j < chips.length; j++) {
            if (chips[j].getAttribute('data-lang') === lang) setChecked(chips[j], newState);
          }
          updateLangFilter();
        });
      }

      if (selectAllBtn) {
        selectAllBtn.addEventListener('click', function() {
          for (var i = 0; i < chips.length; i++) setChecked(chips[i], true);
          updateLangFilter();
        });
      }

      if (deselectAllBtn) {
        deselectAllBtn.addEventListener('click', function() {
          for (var i = 0; i < chips.length; i++) setChecked(chips[i], false);
          updateLangFilter();
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          if (currentPage > 0) showPage(currentPage - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          if (currentPage < totalPages - 1) showPage(currentPage + 1);
        });
      }

      // --- Initialize ---
      updateLangFilter();
      showPage(0);
    })();
  </script>
</BaseLayout>
