---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { localeCodes, DEFAULT_LOCALE } from '../../config/languages';
import { getUI } from '../../i18n';
import { pageAlternates } from '../../lib/utils';

export function getStaticPaths() {
  return localeCodes.map((lang) => ({ params: { lang } }));
}

const { lang = DEFAULT_LOCALE } = Astro.params;
const ui = getUI(lang);
const alternates = pageAlternates('contact');
---

<BaseLayout
  title={`${ui.nav.contact} | ${ui.site.name}`}
  description={ui.site.tagline}
  lang={lang}
  alternates={alternates}
  jsonLd={{
    '@type': 'ContactPage',
    name: ui.nav.contact,
    description: ui.site.tagline,
    inLanguage: lang,
  }}
>
  <main class="mx-auto max-w-2xl px-5 py-20 sm:px-8">
    <p class="font-mono text-xs font-bold uppercase tracking-[0.2em] text-accent">{ui.site.name}</p>
    <h1 class="mt-3 font-display text-4xl font-semibold tracking-tight">{ui.nav.contact}</h1>
    <p class="mt-8 leading-relaxed text-ink-soft">{ui.legal.contactDesc}</p>

    {/* Contact form */}
    <form
      id="contact-form"
      class="mt-10 space-y-5"
      action="https://formspree.io/f/mjgdaqpg"
      method="POST"
    >
      <div>
        <label for="name" class="block font-display text-sm font-semibold text-ink">{ui.contact.yourName}</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="mt-2 block w-full rounded-xl border border-line bg-paper px-4 py-3 text-ink outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent"
        />
      </div>
      <div>
        <label for="email" class="block font-display text-sm font-semibold text-ink">{ui.contact.yourEmail}</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="mt-2 block w-full rounded-xl border border-line bg-paper px-4 py-3 text-ink outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent"
        />
      </div>
      <div>
        <label for="message" class="block font-display text-sm font-semibold text-ink">{ui.contact.message}</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="mt-2 block w-full resize-none rounded-xl border border-line bg-paper px-4 py-3 text-ink outline-none transition-colors focus:border-accent focus:ring-1 focus:ring-accent"
        ></textarea>
      </div>
      <button
        type="submit"
        id="submit-btn"
        class="inline-flex items-center justify-center rounded-xl bg-accent px-6 py-3 font-display text-sm font-semibold text-paper transition-transform duration-200 hover:scale-105 disabled:opacity-50 disabled:hover:scale-100"
      >
        <span id="btn-text">{ui.contact.send}</span>
        <span id="btn-spinner" class="hidden ml-2 h-4 w-4 animate-spin rounded-full border-2 border-paper border-t-transparent"></span>
      </button>
      <p id="form-status" class="hidden text-sm font-semibold"></p>
    </form>

    <div class="mt-12 space-y-6">
      <div class="rounded-2xl border border-line bg-paper-deep p-6">
        <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{ui.contact.emailTitle}</h2>
        <p class="mt-2">
          <a href="mailto:mathias.paulenko@outlook.com" class="text-accent transition-colors hover:underline">
            mathias.paulenko@outlook.com
          </a>
        </p>
      </div>
      <div class="rounded-2xl border border-line bg-paper-deep p-6">
        <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{ui.contact.responseTimeTitle}</h2>
        <p class="mt-2">{ui.contact.responseTimeDesc}</p>
      </div>
      <div class="rounded-2xl border border-line bg-paper-deep p-6">
        <h2 class="font-display text-lg font-semibold tracking-tight text-ink">{ui.contact.whatToIncludeTitle}</h2>
        <ul class="mt-2 list-disc space-y-1 pl-5">
          <li>{ui.contact.whatToInclude1}</li>
          <li>{ui.contact.whatToInclude2}</li>
          <li>{ui.contact.whatToInclude3}</li>
        </ul>
      </div>
    </div>

    <script define:vars={{
      sending: ui.contact.sending,
      sent: ui.contact.sent,
      formError: ui.contact.formError,
    }}>
      const form = document.getElementById('contact-form') as HTMLFormElement;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const btnText = document.getElementById('btn-text') as HTMLSpanElement;
      const spinner = document.getElementById('btn-spinner') as HTMLSpanElement;
      const status = document.getElementById('form-status') as HTMLParagraphElement;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) return;

        const sendText = btnText.textContent || 'Send';

        btn.disabled = true;
        btnText.textContent = sending;
        spinner.classList.remove('hidden');
        status.classList.add('hidden');

        try {
          const response = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { Accept: 'application/json' },
          });

          if (response.ok) {
            status.textContent = sent;
            status.className = 'text-sm font-semibold text-[#2f7a6b]';
            form.reset();
          } else {
            throw new Error();
          }
        } catch {
          status.textContent = formError;
          status.className = 'text-sm font-semibold text-[#b4452a]';
        } finally {
          btn.disabled = false;
          btnText.textContent = sendText;
          spinner.classList.add('hidden');
          status.classList.remove('hidden');
        }
      });
    </script>
  </main>
</BaseLayout>
