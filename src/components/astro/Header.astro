---
import { getCollection } from 'astro:content';
import { localePath, sectionPath } from '../../lib/utils';
import { getUI, languageName } from '../../i18n';
import { interfaceLocales, analyzedLanguages, DEFAULT_LOCALE, type LocaleCode } from '../../config/languages';
import FlagIcon from './FlagIcon.astro';

interface Props {
  lang?: LocaleCode;
}

const { lang = DEFAULT_LOCALE } = Astro.props;
const ui = getUI(lang);

/* Build search index for inline search */
const allTopics = await getCollection('topics');
const topicsByTopic = new Map();
for (const t of allTopics.filter((t) => !t.data.draft)) {
  const topicKey = t.data.topic;
  const existing = topicsByTopic.get(topicKey);
  if (!existing) {
    topicsByTopic.set(topicKey, t);
  } else if (t.data.locale === lang) {
    topicsByTopic.set(topicKey, t);
  } else if (t.data.locale === 'en' && existing.data.locale !== lang) {
    topicsByTopic.set(topicKey, t);
  }
}
const searchData = Array.from(topicsByTopic.values()).map((t) => ({
  title: t.data.title,
  description: t.data.description,
  url: sectionPath(lang, 'topics', t.id),
  difficulty: t.data.difficulty,
}));
---

<header
  data-pagefind-ignore
  class="sticky top-0 z-50 border-b border-line bg-paper/85 backdrop-blur-md"
>
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-6 px-5 sm:px-8">
    <a
      href={localePath(lang)}
      class="group flex items-baseline gap-2 font-display text-xl font-semibold tracking-tight text-ink"
    >
      <span
        class="inline-block h-2.5 w-2.5 translate-y-[-2px] rounded-full bg-accent transition-transform group-hover:scale-125"
        aria-hidden="true"
      ></span>
      Grammar<span class="text-ink-faint">Navigator</span>
    </a>

    <nav class="hidden h-16 items-center gap-0 md:flex" aria-label="Primary">

      <div class="group relative flex h-16 items-center">
        <a href={localePath(lang, 'grammar')} class="flex items-center gap-1 px-3 text-sm font-medium text-ink-soft transition-colors hover:text-ink">
          {ui.nav.grammar}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="transition-transform duration-200 group-hover:rotate-180">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </a>
        <div class="invisible absolute left-0 top-full z-50 w-48 overflow-hidden rounded-xl border border-line bg-paper shadow-lg opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100">
          <div class="py-2">
            <a href={sectionPath(lang, 'topics')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.topics}</a>
            <a href={sectionPath(lang, 'comparisons')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.comparisons}</a>
          </div>
        </div>
      </div>

      <a href={localePath(lang, 'languages')} class="flex h-16 items-center px-3 text-sm font-medium text-ink-soft transition-colors hover:text-ink">
        {ui.nav.languages}
      </a>

      <div class="group relative flex h-16 items-center">
        <a href={localePath(lang, 'vocabulary')} class="flex items-center gap-1 px-3 text-sm font-medium text-ink-soft transition-colors hover:text-ink">
          {ui.nav.vocabulary}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="transition-transform duration-200 group-hover:rotate-180">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </a>
        <div class="invisible absolute left-0 top-full z-50 w-52 overflow-hidden rounded-xl border border-line bg-paper shadow-lg opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100">
          <div class="py-2">
            <a href={localePath(lang, 'vocabulary/words')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.words}</a>
            <a href={localePath(lang, 'vocabulary/phrases')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.phrases}</a>
            <a href={localePath(lang, 'vocabulary/expressions')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.expressions}</a>
          </div>
        </div>
      </div>

      <a href={localePath(lang, 'learning-paths')} class="flex h-16 items-center px-3 text-sm font-medium text-ink-soft transition-colors hover:text-ink">
        {ui.nav.learningPaths}
      </a>

      <div class="group relative flex h-16 items-center">
        <a href={localePath(lang, 'flashcards')} class="flex items-center gap-1 px-3 text-sm font-medium text-ink-soft transition-colors hover:text-ink">
          {ui.nav.flashcards}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="transition-transform duration-200 group-hover:rotate-180">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </a>
        <div class="invisible absolute left-0 top-full z-50 w-48 overflow-hidden rounded-xl border border-line bg-paper shadow-lg opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100">
          <div class="py-2">
            <a href={localePath(lang, 'flashcards/grammar')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.grammar}</a>
            <a href={localePath(lang, 'flashcards/vocabulary')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.vocabulary}</a>
            <a href={localePath(lang, 'flashcards/phrases')} class="block px-4 py-2 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">{ui.nav.phrases}</a>
          </div>
        </div>
      </div>
    </nav>

    {/* Mobile menu toggle */}
    <button
      id="mobile-menu-toggle"
      class="flex items-center justify-center rounded-lg p-2 text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink md:hidden"
      aria-label={ui.nav.menu}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="menu-icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="menu-icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="flex items-center gap-3">
      {/* Inline search (desktop) */}
      <div class="relative hidden sm:block" id="search-bar">
        <div class="relative">
          <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-faint" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/>
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder={ui.search.placeholder}
            class="w-40 rounded-full border border-line bg-paper-deep py-1.5 pl-9 pr-4 text-sm text-ink placeholder:text-ink-faint transition-all focus:w-56 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
            autocomplete="off"
          />
        </div>
        <div id="search-dropdown" class="absolute right-0 top-full z-50 mt-2 hidden w-80 overflow-hidden rounded-xl border border-line bg-paper shadow-lg">
          <ul id="search-results" class="max-h-80 overflow-y-auto py-2"></ul>
        </div>
      </div>
      {/* Search link (mobile) */}
      <a href={localePath(lang, 'search')} class="flex items-center gap-2 rounded-full border border-line px-3 py-1.5 text-sm text-ink-faint transition-colors hover:border-ink-faint hover:text-ink sm:hidden" aria-label={ui.nav.search}>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>
      <script type="application/json" id="search-data" set:html={JSON.stringify(searchData)} />

      <div class="relative">
        <button
          id="lang-toggle"
          class="flex items-center gap-1 rounded-full border border-line px-2.5 py-1.5 text-lg transition-colors hover:bg-paper-deep"
          aria-haspopup="true"
          aria-expanded="false"
          aria-label={ui.footer.interfaceLanguage}
        >
          <FlagIcon code={lang} size={20} />
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="transition-transform text-ink-faint" id="lang-chevron">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>

        <div
          id="lang-menu"
          class="absolute right-0 top-full z-50 mt-2 hidden w-40 overflow-hidden rounded-xl border border-line bg-paper shadow-lg"
          role="menu"
        >
          {
            interfaceLocales.map((locale) => (
              <a
                href={localePath(locale.code)}
                hreflang={locale.htmlLang}
                data-locale-switch={locale.code}
                role="menuitem"
                aria-current={locale.code === lang ? 'true' : undefined}
                class="flex items-center gap-2.5 px-4 py-2.5 text-sm text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink aria-[current]:font-semibold aria-[current]:text-ink"
              >
                <FlagIcon code={locale.code} size={20} />
                {locale.label}
              </a>
            ))
          }
        </div>
      </div>

      <script>
        const toggle = document.getElementById('lang-toggle');
        const menu = document.getElementById('lang-menu');
        const chevron = document.getElementById('lang-chevron');

        if (toggle && menu) {
          toggle.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = !menu.classList.contains('hidden');
            menu.classList.toggle('hidden', isOpen);
            toggle.setAttribute('aria-expanded', String(!isOpen));
            if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
          });

          document.addEventListener('click', () => {
            menu.classList.add('hidden');
            toggle.setAttribute('aria-expanded', 'false');
            if (chevron) chevron.style.transform = '';
          });
        }

        /* Inline search */
        const searchInput = document.getElementById('search-input');
        const searchDropdown = document.getElementById('search-dropdown');
        const searchResults = document.getElementById('search-results');
        const searchDataEl = document.getElementById('search-data');

        if (searchInput && searchDropdown && searchResults && searchDataEl) {
          const allItems = JSON.parse(searchDataEl.textContent || '[]');

          function renderResults(query) {
            const q = query.toLowerCase().trim();
            if (q.length < 2) {
              searchDropdown.classList.add('hidden');
              return;
            }
            const filtered = allItems.filter((item) =>
              item.title.toLowerCase().includes(q) ||
              item.description.toLowerCase().includes(q)
            ).slice(0, 8);

            if (filtered.length === 0) {
              searchResults.innerHTML = `<li class="px-4 py-3 text-center text-sm text-ink-faint">No results</li>`;
            } else {
              searchResults.innerHTML = filtered.map((item) => `
                <li><a href="${item.url}" class="block px-4 py-2.5 transition-colors hover:bg-paper-deep">
                  <p class="text-sm font-medium text-ink">${item.title}</p>
                  <p class="truncate text-xs text-ink-faint">${item.description}</p>
                </a></li>
              `).join('');
            }
            searchDropdown.classList.remove('hidden');
          }

          searchInput.addEventListener('input', (e) => renderResults(e.target.value));
          searchInput.addEventListener('focus', () => { if (searchInput.value.trim().length >= 2) renderResults(searchInput.value); });
          searchInput.addEventListener('keydown', (e) => { if (e.key === 'Escape') searchDropdown.classList.add('hidden'); });
          document.addEventListener('click', (e) => {
            if (!document.getElementById('search-bar')?.contains(e.target)) {
              searchDropdown.classList.add('hidden');
            }
          });
        }

        /* Mobile menu toggle */
        const mobileToggle = document.getElementById('mobile-menu-toggle');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIconOpen = document.getElementById('menu-icon-open');
        const menuIconClose = document.getElementById('menu-icon-close');

        if (mobileToggle && mobileMenu) {
          mobileToggle.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = !mobileMenu.classList.contains('hidden');
            mobileMenu.classList.toggle('hidden', isOpen);
            mobileToggle.setAttribute('aria-expanded', String(!isOpen));
            if (menuIconOpen) menuIconOpen.classList.toggle('hidden', !isOpen);
            if (menuIconClose) menuIconClose.classList.toggle('hidden', isOpen);
          });

          document.addEventListener('click', (e) => {
            if (!mobileMenu.contains(e.target) && !mobileToggle.contains(e.target)) {
              mobileMenu.classList.add('hidden');
              mobileToggle.setAttribute('aria-expanded', 'false');
              if (menuIconOpen) menuIconOpen.classList.remove('hidden');
              if (menuIconClose) menuIconClose.classList.add('hidden');
            }
          });
        }

        /* Language switcher: stay on current page, swap locale prefix */
        document.querySelectorAll('[data-locale-switch]').forEach((link) => {
          link.addEventListener('click', (e) => {
            const newLocale = link.getAttribute('data-locale-switch');
            const currentPath = window.location.pathname;
            const newPath = currentPath.replace(/^\/[a-z]{2}\//, `/${newLocale}/`);
            if (newPath !== currentPath) {
              window.location.href = newPath;
            }
            e.preventDefault();
          });
        });
      </script>
    </div>
  </div>

  {/* Mobile menu drawer */}
  <div
    id="mobile-menu"
    class="hidden absolute left-0 right-0 top-full z-40 border-b border-line bg-paper shadow-lg md:hidden"
    aria-label="Mobile navigation"
  >
    <div class="mx-auto max-w-6xl px-5 py-4 sm:px-8">
      <div class="flex flex-col gap-1">
        <a href={sectionPath(lang, 'topics')} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">
          {ui.nav.topics}
        </a>
        <a href={sectionPath(lang, 'comparisons')} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">
          {ui.nav.comparisons}
        </a>
        <a href={localePath(lang, 'languages')} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">
          {ui.nav.languages}
        </a>
        <a href={localePath(lang, 'vocabulary')} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">
          {ui.nav.vocabulary}
        </a>
        <a href={localePath(lang, 'learning-paths')} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">
          {ui.nav.learningPaths}
        </a>
        <a href={localePath(lang, 'flashcards')} class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-soft transition-colors hover:bg-paper-deep hover:text-ink">
          {ui.nav.flashcards}
        </a>
      </div>
    </div>
  </div>
</header>

